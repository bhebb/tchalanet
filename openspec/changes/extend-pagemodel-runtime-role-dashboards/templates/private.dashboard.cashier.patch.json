{
  "notes": "Patch/reference for completing cashier dashboard template.",
  "row_to_insert_after_quick_sale": {
    "id": "open_draws",
    "label_key": "layout.private_dashboard_cashier.open_draws",
    "columns": [
      {
        "span": 12,
        "widgets": ["dashboard.cashier.open_draws"]
      }
    ]
  },
  "widgets": {
    "dashboard.cashier.overview": {
      "type": "CashierOverviewWidget",
      "binding": { "mode": "dynamic", "source": "cashier.overview" },
      "props": { "title_key": "dashboard.cashier.overview.title" }
    },
    "dashboard.cashier.quick_sale": {
      "type": "QuickSaleWidget",
      "binding": { "mode": "dynamic", "source": "cashier.quick_sale" },
      "props": { "title_key": "dashboard.cashier.quick_sale.title" }
    },
    "dashboard.cashier.open_draws": {
      "type": "OpenDrawsWidget",
      "binding": { "mode": "dynamic", "source": "cashier.open_draws" },
      "props": {
        "title_key": "dashboard.cashier.open_draws.title",
        "max_items": 6
      }
    },
    "dashboard.cashier.recent_tickets": {
      "type": "RecentTicketsWidget",
      "binding": { "mode": "dynamic", "source": "cashier.recent_tickets" },
      "props": {
        "title_key": "dashboard.cashier.recent_tickets.title",
        "max_items": 10
      }
    },
    "dashboard.cashier.session": {
      "type": "SessionSummaryWidget",
      "binding": { "mode": "dynamic", "source": "cashier.session" },
      "props": { "title_key": "dashboard.cashier.session.title" }
    }
  }
}
