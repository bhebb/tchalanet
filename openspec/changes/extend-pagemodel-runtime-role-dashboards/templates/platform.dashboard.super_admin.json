{
  "code": "platform.dashboard.super_admin",
  "logical_id": "platform.dashboard.super_admin",
  "name": "Platform super admin dashboard",
  "label": "platform super admin dashboard",
  "schema_version": 1,
  "schema": {},
  "is_default": true,
  "is_system": true,
  "description": "Tableau de bord plateforme pour super admin: tenants, santé services, flags, jobs, audit et release notes.",
  "model": {
    "meta": {
      "id": "platform.dashboard.super_admin",
      "scope": "PLATFORM",
      "slug": "dashboard",
      "context": "platform_dashboard_super_admin",
      "schema_version": 1,
      "langs": ["fr", "en", "ht"],
      "default_lang": "fr",
      "required_roles": ["SUPER_ADMIN"],
      "description": "Dashboard plateforme pour super admin."
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "header": {
        "component": "PrivateHeader",
        "nav": { "primary": [], "secondary": [] },
        "props": { "show_profile_menu": true }
      },
      "sidenav": {
        "component": "PrivateSidenav",
        "nav": {
          "primary": [
            { "label_key": "nav.dashboard", "path": "/app/platform", "icon": "dashboard" },
            { "label_key": "nav.tenants", "path": "/app/platform/tenants", "icon": "business" },
            { "label_key": "nav.users", "path": "/app/platform/users", "icon": "group" },
            {
              "label_key": "nav.service_health",
              "path": "/app/platform/health",
              "icon": "monitor_heart"
            },
            { "label_key": "nav.feature_flags", "path": "/app/platform/flags", "icon": "flag" },
            { "label_key": "nav.themes", "path": "/app/platform/themes", "icon": "palette" },
            { "label_key": "nav.i18n", "path": "/app/platform/i18n", "icon": "translate" },
            { "label_key": "nav.ops_jobs", "path": "/app/platform/jobs", "icon": "deployed_code" },
            { "label_key": "nav.audit", "path": "/app/platform/audit", "icon": "history" }
          ],
          "secondary": []
        },
        "props": { "collapsible": true }
      },
      "footer": {
        "component": "PrivateFooter",
        "nav": {
          "primary": [],
          "secondary": [
            { "label_key": "footer.support", "path": "/support", "icon": "support_agent" }
          ]
        },
        "props": {}
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "overview",
            "label_key": "layout.platform_dashboard_super_admin.overview",
            "columns": [{ "span": 12, "widgets": ["dashboard.platform.overview"] }]
          },
          {
            "id": "tenants",
            "label_key": "layout.platform_dashboard_super_admin.tenants",
            "columns": [{ "span": 12, "widgets": ["dashboard.platform.tenants"] }]
          },
          {
            "id": "services",
            "label_key": "layout.platform_dashboard_super_admin.services",
            "columns": [{ "span": 12, "widgets": ["dashboard.platform.services"] }]
          },
          {
            "id": "flags_jobs",
            "label_key": "layout.platform_dashboard_super_admin.flags_jobs",
            "columns": [
              { "span": 6, "widgets": ["dashboard.platform.flags"] },
              { "span": 6, "widgets": ["dashboard.platform.jobs"] }
            ]
          },
          {
            "id": "audit_release",
            "label_key": "layout.platform_dashboard_super_admin.audit_release",
            "columns": [
              { "span": 6, "widgets": ["dashboard.platform.audit"] },
              { "span": 6, "widgets": ["dashboard.platform.release_notes"] }
            ]
          }
        ]
      },
      "widgets": {
        "dashboard.platform.overview": {
          "type": "PlatformOverviewWidget",
          "binding": { "mode": "dynamic", "source": "platform.overview" },
          "props": { "title_key": "dashboard.platform.overview.title" }
        },
        "dashboard.platform.tenants": {
          "type": "PlatformTenantsWidget",
          "binding": { "mode": "dynamic", "source": "platform.tenants" },
          "props": { "title_key": "dashboard.platform.tenants.title" }
        },
        "dashboard.platform.services": {
          "type": "PlatformServicesWidget",
          "binding": { "mode": "dynamic", "source": "platform.services.health" },
          "props": { "title_key": "dashboard.platform.services.title" }
        },
        "dashboard.platform.flags": {
          "type": "PlatformFlagsWidget",
          "binding": { "mode": "dynamic", "source": "platform.flags" },
          "props": { "title_key": "dashboard.platform.flags.title" }
        },
        "dashboard.platform.jobs": {
          "type": "PlatformJobsWidget",
          "binding": { "mode": "dynamic", "source": "platform.jobs" },
          "props": { "title_key": "dashboard.platform.jobs.title" }
        },
        "dashboard.platform.audit": {
          "type": "PlatformAuditWidget",
          "binding": { "mode": "dynamic", "source": "platform.audit" },
          "props": { "title_key": "dashboard.platform.audit.title" }
        },
        "dashboard.platform.release_notes": {
          "type": "ReleaseNotesWidget",
          "binding": { "mode": "dynamic", "source": "platform.release_notes" },
          "props": { "title_key": "dashboard.platform.release_notes.title" }
        }
      }
    }
  }
}
