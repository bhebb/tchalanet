<?xml version="1.0" encoding="utf-8"?>
<!--
  network_security_config.xml — dev only

  1. Trust the local mkcert CA for *.localtest.me (Traefik dev certs).
     The rootCA.pem is generated by `mkcert -install` on the dev machine.
     Copy it to res/raw/mkcert_ca.pem whenever the mkcert CA is regenerated.

  2. Allow cleartext HTTP to the Android emulator host (10.0.2.2) for the
     backend API. Physical device: replace 10.0.2.2 with your LAN IP.

  Never add production domains or system CA overrides here.
-->
<network-security-config>

    <!-- Trust mkcert CA for local HTTPS domains (Traefik + Keycloak) -->
    <domain-config>
        <domain includeSubdomains="true">localtest.me</domain>
        <trust-anchors>
            <certificates src="@raw/mkcert_ca"/>
            <certificates src="system"/>
        </trust-anchors>
    </domain-config>

    <!-- Allow cleartext HTTP to emulator host for the backend API -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

</network-security-config>
