# Environment (override in env-specific compose.env)
ENV=prod

# Image versions
IMAGE_TAG=stg-20251114-2
TRAEFIK_IMAGE=traefik:v3.5.4
UNLEASH_IMAGE=unleashorg/unleash-server:7.2.3
MEILI_IMAGE=getmeili/meilisearch:v1.11
API_IMAGE_BASE=ghcr.io/bhebb/tchalanet-api
KEYCLOAK_IMAGE=ghcr.io/bhebb/tchalanet-keycloak:stg-20251114-2
POSTGRES_VERSION=18
REDIS_IMAGE=redis:8.2.3
DOPPLER_IMAGE=dopplerhq/cli:latest

# Docker naming
DOCKER_PREFIX=tchl
DOCKER_NETWORK_EDGE=edge-dev
DOCKER_NETWORK_BACK=back-dev

# Container names (interpolation)
POSTGRES_CONTAINER=tchl-postgres
REDIS_CONTAINER=tchl-redis
KEYCLOAK_CONTAINER=tchl-keycloak
API_CONTAINER=tchl-api
MEILI_CONTAINER=tchl-meili

# Volume names
POSTGRES_VOLUME=pgdata
KEYCLOAK_DATA_VOLUME=keycloak-data

# Database names & users (non-secret defaults)
KC_DB_NAME=keycloak_db
KC_DB_USERNAME=kc_user
APP_DB_NAME=tchalanet_db
APP_DB_USER=app_user
UNLEASH_DB_NAME=unleash_db
UNLEASH_DB_USER=unleash_user

POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_INITDB_ARGS=--data-checksums
POSTGRES_HOST_AUTH_METHOD=scram-sha-256

PG_SHARED_BUFFERS=256MB
PG_WORK_MEM=16MB
PG_MAINTENANCE_WORK_MEM=128MB
PG_EFFECTIVE_CACHE_SIZE=1GB
PG_MEMORY_LIMIT=2G
PG_MEMORY_RESERVATION=1G

# Logging config (interpolation)
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3
PG_LOG_MAX_SIZE=10m
PG_LOG_MAX_FILES=3
KC_LOG_MAX_SIZE=10m
KC_LOG_MAX_FILES=3
API_LOG_MAX_SIZE=10m
API_LOG_MAX_FILES=3
REDIS_LOG_MAX_SIZE=10m
REDIS_LOG_MAX_FILES=3
UNLEASH_LOG_MAX_SIZE=10m
UNLEASH_LOG_MAX_FILES=3

# Traefik labels
API_TRAEFIK_ENABLE=true
UNLEASH_TRAEFIK_ENABLE=true

# Ports
API_PORT=8080
UNLEASH_EDGE_HOST_PORT=4242

# Keycloak JVM (interpolation)
KC_EXTRA_ARGS=
KC_XMS=512m
KC_XMX=1024m
KC_METASPACE_SIZE=96M
KC_MAX_METASPACE_SIZE=256m

# Google Analytics (optional)
GA_MEASUREMENT_ID=

