# envs/common/edge-service.env
# Variables pour le service edge (tchalanet-edge-service).
# Copier les secrets dans envs/<ENV>/.secrets (jamais versionner les secrets).

# ── Image (build local) ──────────────────────────────────────────────────────
TCH_EDGE_IMAGE=tchalanet-edge-service
TCH_EDGE_TAG=local

# ── Secret HMAC partagé ──────────────────────────────────────────────────────
# Même valeur que TCH_EDGE_HMAC_SECRET dans api.env.
# Générer : openssl rand -base64 32
# → à mettre dans envs/<ENV>/.secrets, pas ici.
EDGE_HMAC_SECRET=change-me-long-random-secret

# ── Intégration backend (API → Edge) ─────────────────────────────────────────
# Ces variables doivent être présentes dans envs/common/api.env :
#   TCH_EDGE_BASE_URL=http://edge-service:3000
#   TCH_EDGE_HMAC_SECRET=${EDGE_HMAC_SECRET}

# ── Slack ────────────────────────────────────────────────────────────────────
SLACK_ENABLED=false
SLACK_WEBHOOK_TCHALANET=
SLACK_WEBHOOK_BATCH_DRAWS=
SLACK_WEBHOOK_DELIVERY=
SLACK_WEBHOOK_OPS_ALERTS=
SLACK_WEBHOOK_SECURITY_AUDIT=

# ── Email (Brevo) ─────────────────────────────────────────────────────────────
EMAIL_ENABLED=false
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
EMAIL_FROM_NAME=Tchalanet
EMAIL_FROM_ADDRESS=no-reply@example.com

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
SMS_ENABLED=false
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
