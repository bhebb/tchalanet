UNLEASH_CONTAINER=unleash
# UNLEASH_DB_PASSWORD -> inject via envs/<env>/.env
UNLEASH_METRICS_ENABLED=true
UNLEASH_DISABLE_REQUEST_LOGGING=false
UNLEASH_MAX_OLD_SPACE_SIZE=512
UNLEASH_MAX_SEMI_SPACE_SIZE=128
UNLEASH_LOG_MAX_SIZE=10m
UNLEASH_LOG_MAX_FILES=3
TZ=UTC
# libpq defaults (used by Node pg client)
#PGUSER=unleash_user
#PGDATABASE=unleash_db
# PGPASSWORD -> inject via envs/<env>/.secrets as UNLEASH_DB_PASSWORD or PGPASSWORD

# Unleash official database envs (read by the server)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=unleash_db
DATABASE_USERNAME=unleash_user


