# envs/common/api.env - API runtime defaults (NON-SECRETS)
# SPRING profile par défaut = prod (dev/staging doivent surcharger)
SPRING_PROFILES_ACTIVE=prod

# Authentication provider
TCH_IDENTITY_PROVIDER=firebase

# Redis (Docker-internal — via réseau back)
TCH_REDIS_URL=redis://redis:6379

# Edge service (Docker-internal — via réseau back)
TCH_EDGE_BASE_URL=http://edge-service:3000
# TCH_EDGE_HMAC_SECRET → inject via envs/<env>/.secrets

# SPRING_DATASOURCE_URL → set per-env:
#   dev:          jdbc:postgresql://postgres:5432/tchalanet_db  (local container)
#   staging/prod: jdbc:postgresql://...neon.tech/tchalanet_db?sslmode=require  (Doppler → .secrets)

# OTel — override per environment when using an external collector
OTEL_ENDPOINT=http://otel-collector:4318/v1/traces

# Resource limits (production defaults)
API_MEMORY_LIMIT=2G
API_MEMORY_RESERVATION=1G
API_CPU_LIMIT=2
API_CPU_RESERVATION=1
