# envs/common/api.env - API runtime defaults (PRODUCTION, NON-SECRETS)
API_CONTAINER=tch-api
# IMAGE_TAG géré dans envs/<env>/compose.env (prod-latest en prod, stg-latest en staging)
# SPRING profile par défaut = prod (environnements dev/staging doivent surcharger)
SPRING_PROFILES_ACTIVE=prod
# DB defaults (non-secrets)
APP_DB_NAME=tchalanet_db
APP_DB_USER=app_user
# APP_DB_PASSWORD -> inject via envs/<env>/.secrets
# Keycloak (production)
TCH_KC_AUDIENCE=tch-api
# TCH_KC_ISSUER must be set per-environment (envs/<env>/.env) — no common default
# Redis/Flags/Umami endpoints (production)
TCH_REDIS_URL=redis://redis:6379

# Edge service (Docker-internal — via réseau back)
TCH_EDGE_BASE_URL=http://edge-service:3000
# TCH_EDGE_HMAC_SECRET doit correspondre à EDGE_HMAC_SECRET → injecter via envs/<env>/.secrets

# Resource limits (production defaults)
API_MEMORY_LIMIT=2G
API_MEMORY_RESERVATION=1G
API_CPU_LIMIT=2
API_CPU_RESERVATION=1
