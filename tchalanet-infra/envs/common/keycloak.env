# envs/common/keycloak.env - keycloak runtime defaults (PRODUCTION, NON-SECRETS)
# Put non-sensitive Keycloak runtime configuration here. Secrets (passwords) must be injected per-env.
KEYCLOAK_CONTAINER=tch-keycloak
KEYCLOAK_DATA_VOLUME=keycloak-data
KC_DB=postgres
KC_DB_URL_HOST=postgres
KC_DB_URL_PORT=5432
KC_DB_URL_DATABASE=keycloak_db
KC_DB_USERNAME=kc_user
# KC_DB_PASSWORD -> inject via envs/<env>/.secrets (Doppler/CI)
# Hostname (Keycloak 26 hostname v2: KC_HOSTNAME accepts a full URL).
# KC_HOSTNAME_URL is the v1 deprecated option — removed to silence the startup warning.
KC_HOSTNAME_STRICT=false
KC_HOSTNAME=https://auth.tchalanet.com
# Admin bootstrap (Keycloak 26+)
KC_BOOTSTRAP_ADMIN_USERNAME=admin
# KC_BOOTSTRAP_ADMIN_PASSWORD -> inject via envs/<env>/.secrets or Doppler
KC_XMS=512m
KC_XMX=1024m
KC_METASPACE_SIZE=96M
KC_MAX_METASPACE_SIZE=256m
KC_LOG_MAX_SIZE=10m
KC_LOG_MAX_FILES=3
TZ=UTC
# Production realm/host by default (dev/staging must override if different)
KC_HOST=auth.tchalanet.com
KC_REALM=tchalanet
KC_CLIENT_ID=tch-client
