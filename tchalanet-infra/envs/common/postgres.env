# envs/common/postgres.env - PostgreSQL local container config (dev only)
# Staging/prod use Neon — SPRING_DATASOURCE_URL comes from Doppler → .secrets

POSTGRES_USER=postgres
POSTGRES_DB=postgres
POSTGRES_INITDB_ARGS=--data-checksums
POSTGRES_HOST_AUTH_METHOD=scram-sha-256
POSTGRES_CONTAINER=tchl-postgres
POSTGRES_VOLUME=pgdata

APP_DB_NAME=tchalanet_db
APP_DB_USER=app_user
# APP_DB_PASSWORD → inject via envs/dev/.secrets
