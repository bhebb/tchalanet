# envs/common/redis.env - Redis runtime defaults (PRODUCTION, NON-SECRETS)
REDIS_CONTAINER=tchalanet-redis
REDIS_MAX_MEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_APPENDONLY=yes
REDIS_APPENDFSYNC=everysec
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_LOG_MAX_SIZE=10m
REDIS_LOG_MAX_FILES=3
# Note: REDIS_PASSWORD must be injected per-environment (Doppler/CI) into envs/<env>/.secrets
