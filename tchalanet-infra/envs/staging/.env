POSTGRES_USER=admin
POSTGRES_PASSWORD=staging_pg_pwd
# Hosts (staging-specific)
API_HOST=api.stg.tchalanet.com
FLAGS_HOST=flags.stg.tchalanet.com
STATS_HOST=stats.stg.tchalanet.com
APP_WEB_ORIGIN=https://test.tchalanet.com,https://auth.stg.tchalanet.com,https://stg.tchalanet.com,https://api.stg.tchalanet.com
# Spring Boot (staging profile)
SPRING_PROFILES_ACTIVE=staging
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/tchalanet_db
SPRING_DATASOURCE_USERNAME=app_user

KC_DB=keycloak_db
KC_USER=kc
KC_PASS=staging_kc_pwd
KC_ADMIN=admin
KC_ADMIN_PASS=staging_kc_admin

APP_DB=tchalanet_db
APP_USER=app
APP_PASS=staging_app_pwd
UN_DB=unleash

KC_HOST=auth.staging.tchalanet.com
APP_WEB_HOST=app.staging.tchalanet.com

# Keycloak runtime
TCH_KC_ISSUER=https://auth.stg.tchalanet.com/realms/tchalanet

# API service URLs
TCH_REDIS_URL=redis://redis:6379
TCH_FLAGS_URL=http://unleash:4242/api
