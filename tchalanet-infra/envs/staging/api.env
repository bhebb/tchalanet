# envs/staging/api.env - API runtime overrides for staging (non-secrets)
SPRING_PROFILES_ACTIVE=staging
# Utiliser Unleash Edge pour l’API (proxy public)
TCH_FLAGS_URL=https://flags.stg.tchalanet.com/proxy

# Spring Security JWT — override application.yaml hardcoded issuer-uri
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=https://auth.stg.tchalanet.com/realms/tchalanet
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_JWK_SET_URI=http://keycloak:8080/realms/tchalanet/protocol/openid-connect/certs
