# envs/staging/.secrets.example - placeholders (do not commit real secrets)
# Copy to envs/staging/.secrets and fill via Doppler or local export for testing.

# Unleash Edge: token used by Edge to talk to Unleash upstream (server/admin)
UNLEASH_SERVER_TOKEN=__SET_IN_DOPPLER__

# Unleash Edge: frontend token exposed to browsers/clients (limited rights)
# Example (single token):
UNLEASH_FRONTEND_TOKEN=__SET_IN_DOPPLER__

# Optional: basic auth for Unleash Admin UI when exposed via Traefik (htpasswd format)
# Generate with: htpasswd -nbB admin 'your-password'  (Apache htpasswd). Paste full 'user:hash' here.
UNLEASH_DASHBOARD_AUTH=admin:$2y$05$replace_with_bcrypt_hash

# Optional: restrict CORS for Edge (recommended in prod)
# Set to your web origin, e.g. https://web.stg.tchalanet.com
UNLEASH_EDGE_CORS_ORIGIN=
