# Compose-time variables (staging)
# Override/extend common compose.env for staging environment

# Docker networks (staging-specific)
DOCKER_NETWORK_EDGE=edge-staging
DOCKER_NETWORK_BACK=back-staging

# Environment
ENV=staging

# Optional: Override image tags for staging if different from common
# API_IMAGE_BASE=ghcr.io/bhebb/tchalanet-api
# KEYCLOAK_IMAGE=ghcr.io/bhebb/tchalanet-keycloak:stg-20251114

