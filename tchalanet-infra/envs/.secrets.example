# .secrets — Doppler secrets (DO NOT COMMIT)
# This file is downloaded via: make doppler-download-staging / make doppler-download-prod
# All passwords, tokens, and sensitive credentials go here

# === Postgres passwords (used by postgres-init.sh) ===
POSTGRES_PASSWORD=
APP_DB_PASSWORD=
UNLEASH_DB_PASSWORD=


# === Redis password (optional, leave empty for no auth in dev) ===
REDIS_PASSWORD=

# === Meilisearch master key ===
MEILI_MASTER_KEY=

# === API secrets ===
# JWT secret, OAuth client secrets, etc.
API_JWT_SECRET=

# === Unleash tokens ===
UNLEASH_ADMIN_TOKEN=
UNLEASH_CLIENT_TOKEN=

# === External services (if needed) ===
# SMTP_PASSWORD=
# S3_SECRET_KEY=
# SENTRY_DSN=

