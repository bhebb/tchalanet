# envs/dev/.env - Dev-specific runtime variables (NON-SECRETS)
# Only overrides, common values are in common/.env

# Hosts (dev-specific)
API_HOST=api.localtest.me
APP_WEB_HOST=app.localtest.me
LAN_API_HOST=api.tchalanet.lan
LAN_APP_WEB_HOST=app.tchalanet.lan
FLAGS_HOST=flags.localtest.me
STATS_HOST=stats.localtest.me
EDGE_HOST=edge.localtest.me
TRAEFIK_HOST=traefik.localtest.me

# Spring Boot (dev profile)
SPRING_PROFILES_ACTIVE=dev,insecure
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/tchalanet_db
SPRING_DATASOURCE_USERNAME=app_user
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_FLYWAY_ENABLED=true
TCH_OFFLINESYNC_ENABLED=true

# API dev config
API_ADMIN_TOKEN=local-dev-token
# Public ticket verification URL — dev uses the local web app
TCH_TICKET_PUBLIC_BASE_URL=https://app.localtest.me
TCH_REDIS_URL=redis://redis:6379
TCH_FLAGS_URL=http://unleash:4242/api

# Spring Security JWT — override application.yaml hardcoded issuer-uri
# InsecureJwtDecoderConfig uses jwk-set-uri directly — no OIDC discovery at startup
# Traefik dev
TRAEFIK_DASHBOARD_AUTH=admin:devpassword

# Unleash dev
UNLEASH_SERVER_TOKEN=default:development

# Monitoring
ENABLE_METRICS=true
OTEL_ENABLED=true
OTEL_ENDPOINT=http://otel-collector:4318/v1/traces
OTEL_SAMPLER_PROBABILITY=1.0

# Logback — override Spring Boot 3.4.x default pattern that uses %logger{1.} syntax
# (requires Logback 1.5.12+; image bundles an older version)
LOGGING_PATTERN_CONSOLE="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %-5p \${PID:- } --- [%15.15t] %-40.40logger{39} : %m%n%wEx"
