# Compose-time variables (dev)
# Override/extend common compose.env for dev environment

# Docker networks (dev-specific)
DOCKER_NETWORK_EDGE=edge-dev
DOCKER_NETWORK_BACK=back-dev

# Environment
ENV=dev

# Optional: Override image tags for dev if different from common
# Use locally-built Keycloak image with custom providers
KEYCLOAK_IMAGE=tchl/keycloak:local-dev
IMAGE_TAG=local-dev

# Traefik dashboard en dev via port 8080
TRAEFIK_API_INSECURE=true

# Keycloak hostname pour dev local Mac (Keycloak v26 hostname v2 — URL complète).
# Pour tester depuis une autre machine du LAN, override avec :
#   KC_HOSTNAME=http://auth.tchalanet.lan
KC_HOSTNAME=https://auth.localtest.me
KC_LAN_HOST=auth.tchalanet.lan

# API Spring profile for Docker dev
SPRING_PROFILES_ACTIVE=dev,insecure
