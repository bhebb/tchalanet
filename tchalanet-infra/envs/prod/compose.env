# Compose-time variables (production)
# Override/extend common compose.env for production environment

# Docker networks (production-specific)
DOCKER_NETWORK_EDGE=edge-prod
DOCKER_NETWORK_BACK=back-prod

# Environment
ENV=prod

# Keycloak hostname pour prod
KC_HOSTNAME=https://auth.tchalanet.com
KC_TRAEFIK_ENTRYPOINTS=websecure
KC_TRAEFIK_TLS=true
KC_FORWARDED_PROTO=https
KC_LAN_HOST=disabled.invalid

# Optional: Override image tags for production if different from common
# API_IMAGE_BASE=ghcr.io/bhebb/tchalanet-api
# KEYCLOAK_IMAGE=ghcr.io/bhebb/tchalanet-keycloak:prd-v1.0.0
