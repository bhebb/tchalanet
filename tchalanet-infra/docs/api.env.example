Pourquoi QUARKUS # ========================================
# Tchalanet API - Configuration Dev Local
# ========================================
# À placer dans : tchalanet-server/.env
# IMPORTANT : Ce fichier ne doit PAS être versionné (ajouter à .gitignore)

# ========================================
# 🗄️ Postgres (Database)
# ========================================
# Les valeurs doivent correspondre à tchalanet-infra/envs/dev/.secrets
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=devpass

# ========================================
# 🔴 Redis (Cache)
# ========================================
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=devredis

# ========================================
# 🔐 Keycloak (Authentication)
# ========================================
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://localhost:8082/realms/tchalanet-dev
KEYCLOAK_REALM=tchalanet-dev
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8082
KEYCLOAK_RESOURCE=tchalanet-api
KEYCLOAK_CREDENTIALS_SECRET=change-me-in-production

# ========================================
# 🚩 Unleash (Feature Flags)
# ========================================
UNLEASH_API_URL=http://localhost:4242/api
UNLEASH_API_TOKEN=*:*.dev-edge-token
UNLEASH_APP_NAME=tchalanet-api
UNLEASH_ENVIRONMENT=dev

# ========================================
# 🔍 Meilisearch (Search Engine)
# ========================================
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=yK8vN2wR5tA9xP3mL7hQ6sD1

# ========================================
# 🔧 Application Config
# ========================================
SERVER_PORT=8081
SPRING_PROFILES_ACTIVE=dev
LOGGING_LEVEL_ROOT=INFO
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ========================================
# 🌐 CORS (Frontend)
# ========================================
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201

# ========================================
# Notes
# ========================================
# - Tous les services doivent être démarrés via tchalanet-infra (make up-all ENV=dev)
# - Les passwords doivent correspondre exactement à ceux de l'infra
# - Pour lancer l'API : cd tchalanet-server && set -a; source .env; set +a; ./mvnw quarkus:dev
# - Analytics (Google Analytics). Use GA_MEASUREMENT_ID to configure frontend analytics
# GA_MEASUREMENT_ID=G-XXXXXXXX
