{
  "name": "tchalanet-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "tch",
  "sourceRoot": "apps/tchalanet-web/src",
  "tags": ["type:app", "scope:web"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/tchalanet-web",
        "browser": "apps/tchalanet-web/src/main.ts",
        "polyfills": ["zone.js"],
        "tsConfig": "apps/tchalanet-web/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "libs/i18n/locales",
            "output": "/assets/i18n"
          },
          {
            "glob": "**/*",
            "input": "apps/tchalanet-web/public"
          }
        ],
        "styles": ["apps/tchalanet-web/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all",
          "fileReplacements": []
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "libs/shared/config/src/lib/environments/environment.ts",
              "with": "libs/shared/config/src/lib/environments/environment-local-ide.ts"
            }
          ]
        },
        "ci": {
          "optimization": true,
          "sourceMap": false,
          "budgets": [
            { "type": "initial", "maximumWarning": "2.5mb", "maximumError": "3mb" },
            { "type": "anyComponentStyle", "maximumWarning": "400kb", "maximumError": "600kb" }
          ]
        },
        "vercel": {
          "optimization": true,
          "sourceMap": false,
          "extractLicenses": true,
          "outputHashing": "all",
          "budgets": [
            { "type": "initial", "maximumWarning": "2.5mb", "maximumError": "3mb" },
            { "type": "anyComponentStyle", "maximumWarning": "400kb", "maximumError": "600kb" }
          ]
        },
        "staging": {
          "fileReplacements": [
            {
              "replace": "libs/shared/config/src/lib/environments/environment.ts",
              "with": "libs/shared/config/src/lib/environments/environment-staging.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "tchalanet-web:build:production"
        },
        "development": {
          "buildTarget": "tchalanet-web:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "tchalanet-web:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../coverage/apps/tchalanet-web"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "tchalanet-web:build",
        "port": 4300,
        "staticFilePath": "dist/apps/tchalanet-web/browser",
        "spa": true
      }
    },
    "lint-styles": {
      "executor": "nx:run-commands",
      "options": {
        "command": "stylelint \"apps/tchalanet-web/src/**/*.scss\" \"libs/**/src/**/*.scss\""
      }
    }
  }
}
