{
  "meta": {
    "logicalId": "private.dashboard.fallback",
    "scope": "private",
    "slug": "dashboard",
    "schemaVersion": 2,
    "currentLang": "fr",
    "supportedLangs": [
      {
        "code": "fr",
        "label": "Français",
        "shortLabel": "FR"
      }
    ]
  },
  "shell": {
    "type": "private",
    "topAppBar": {
      "titleKey": "dashboard.fallback.title"
    },
    "navigationDrawer": {
      "primary": []
    }
  },
  "content": {
    "layout": {
      "rows": [
        {
          "id": "fallback-status",
          "columns": [
            {
              "span": 12,
              "widgets": ["dashboard.fallback.notice", "dashboard.fallback.status"]
            }
          ]
        },
        {
          "id": "fallback-actions",
          "columns": [
            {
              "span": 12,
              "widgets": ["dashboard.fallback.actions"]
            }
          ]
        }
      ]
    },
    "widgets": {
      "dashboard.fallback.notice": {
        "type": "AlertsWidget",
        "props": {
          "titleKey": "dashboard.fallback.notice.title",
          "emptyKey": "dashboard.fallback.notice.empty"
        }
      },
      "dashboard.fallback.status": {
        "type": "KpiGridWidget",
        "props": {
          "titleKey": "dashboard.fallback.status.title",
          "items": [
            {
              "id": "runtime",
              "labelKey": "dashboard.fallback.status.runtime",
              "icon": "cloud_off",
              "tone": "warning",
              "value": "Dégradé"
            },
            {
              "id": "support",
              "labelKey": "dashboard.fallback.status.support",
              "icon": "support_agent",
              "tone": "neutral",
              "value": "Référence requise"
            }
          ]
        }
      },
      "dashboard.fallback.actions": {
        "type": "QuickActionsWidget",
        "props": {
          "titleKey": "dashboard.fallback.actions.title",
          "actions": [
            {
              "id": "admin.setup",
              "labelKey": "dashboard.fallback.actions.setup",
              "icon": "checklist",
              "destination": {
                "kind": "route",
                "value": "/app/admin/setup"
              }
            },
            {
              "id": "admin.support",
              "labelKey": "dashboard.fallback.actions.support",
              "icon": "support_agent",
              "destination": {
                "kind": "route",
                "value": "/app/admin/company/support"
              }
            }
          ]
        }
      }
    }
  },
  "dynamic": {
    "widgets": {
      "dashboard.fallback.notice": {
        "items": [
          {
            "id": "dashboard-fallback-active",
            "title": "Tableau de bord temporairement indisponible",
            "message": "Les services principaux restent accessibles depuis les actions disponibles.",
            "severity": "WARN"
          }
        ]
      },
      "dashboard.fallback.status": {},
      "dashboard.fallback.actions": {}
    },
    "errors": []
  }
}
