    "tch-portal": {
      "name": "tch-portal",
      "type": "app",
      "data": {
        "root": "apps/tch-portal",
        "targets": {
          "lint": {
            "executor": "@nx/eslint:lint",
            "options": {},
            "configurations": {},
            "parallelism": true,
            "cache": true,
            "inputs": [
              "default",
              "^default",
              "{workspaceRoot}/.eslintrc.json",
              "{workspaceRoot}/.eslintignore",
              "{workspaceRoot}/eslint.config.mjs",
              "{workspaceRoot}/tools/eslint-rules/**/*"
            ]
          },
          "build": {
            "executor": "@angular/build:application",
            "outputs": [
              "{options.outputPath}"
            ],
            "options": {
              "outputPath": "dist/apps/tch-portal",
              "browser": "apps/tch-portal/src/main.ts",
              "tsConfig": "apps/tch-portal/tsconfig.app.json",
              "inlineStyleLanguage": "scss",
              "stylePreprocessorOptions": {
                "includePaths": [
                  "libs/ui/theme/src",
                  "libs/ui/styles/src/lib"
                ]
              },
              "assets": [
                {
                  "glob": "**/*",
                  "input": "apps/tch-portal/public"
                }
              ],
              "styles": [
                "apps/tch-portal/src/styles.scss"
              ]
            },
            "configurations": {
              "production": {
                "fileReplacements": [
                  {
                    "replace": "apps/tch-portal/src/environments/environment.ts",
                    "with": "apps/tch-portal/src/environments/environment.prod.ts"
                  }
                ],
                "budgets": [
                  {
                    "type": "initial",
                    "maximumWarning": "1mb",
                    "maximumError": "2mb"
                  },
                  {
                    "type": "anyComponentStyle",
                    "maximumWarning": "8kb",
                    "maximumError": "20kb"
                  }
                ],
                "outputHashing": "all"
              },
              "development": {
                "optimization": false,
                "extractLicenses": false,
                "sourceMap": true
              },
              "real-firebase": {
                "fileReplacements": [
                  {
                    "replace": "apps/tch-portal/src/environments/environment.ts",
                    "with": "apps/tch-portal/src/environments/environment.real-firebase.ts"
                  }
                ],
                "optimization": false,
                "extractLicenses": false,
                "sourceMap": true
              }
            },
            "defaultConfiguration": "production",
            "parallelism": true,
            "cache": true,
            "dependsOn": [
              "^build"
            ],
            "inputs": [
              "default",
              "^default"
            ]
          },
          "serve": {
            "continuous": true,
            "executor": "@angular/build:dev-server",
            "options": {
              "proxyConfig": "apps/tch-portal/proxy.conf.cjs"
            },
            "configurations": {
              "production": {
                "buildTarget": "tch-portal:build:production"
              },
              "development": {
                "buildTarget": "tch-portal:build:development"
              },
              "real-firebase": {
                "buildTarget": "tch-portal:build:real-firebase"
              }
            },
            "defaultConfiguration": "development",
            "parallelism": true
          },
          "test": {
            "executor": "@angular/build:unit-test",
            "options": {
              "watch": false
            },
            "configurations": {},
            "parallelism": true,
            "cache": true,
            "inputs": [
              "default",
              "^default"
            ]
          },
          "serve-static": {
            "continuous": true,
            "executor": "@nx/web:file-server",
            "options": {
              "buildTarget": "tch-portal:build",
              "port": 4200,
              "staticFilePath": "dist/apps/tch-portal/browser",
              "spa": true
            },
            "configurations": {},
            "parallelism": true
          }
        },
        "name": "tch-portal",
        "$schema": "../../node_modules/nx/schemas/project-schema.json",
        "projectType": "application",
        "prefix": "tch",
        "sourceRoot": "apps/tch-portal/src",
        "tags": [
          "lottery",
          "haiti",
          "borlette"
        ],
        "implicitDependencies": []
      }
    },
