# ── API ─────────────────────────────────────────────────────────────────────
TCH_BASE_URL=http://localhost:8083/api/v1
TCH_E2E_VERIFY_SSL=false
TCH_E2E_AUTH_PROVIDER=keycloak

# ── Local JWT / perf auth (set provider to local-jwt or local-perf) ──────────
# TCH_LOCAL_JWT_ISSUER=tchalanet-local
# TCH_LOCAL_JWT_SECRET=dev-only-change-me-at-least-32-characters

# ── Keycloak ─────────────────────────────────────────────────────────────────
TCH_KEYCLOAK_TOKEN_URL=http://localhost:8180/realms/tchalanet/protocol/openid-connect/token
TCH_KEYCLOAK_CLIENT_ID=tchalanet-swagger
# TCH_KEYCLOAK_CLIENT_SECRET=

# ── Super admin ───────────────────────────────────────────────────────────────
TCH_SUPER_ADMIN_USERNAME=superadmin
TCH_SUPER_ADMIN_PASSWORD=

# ── Tenant A (seed — migration V205) ─────────────────────────────────────────
TCH_TENANT_ID=00000000-0000-0000-0000-000000000003
TCH_TENANT_CODE=tchalanet
TCH_OUTLET_ID=00000000-0000-0000-0000-000000003001
TCH_TERMINAL_ID=00000000-0000-0000-0000-000000003101
TCH_SELLER_USERNAME=seller
TCH_SELLER_PASSWORD=
TCH_STAKE_CENTS=100
TCH_GENERATE_DAYS=7

# ── Tenant B (optional — different config) ────────────────────────────────────
# TCH_TENANT_2_CODE=
# TCH_TENANT_2_ID=
# TCH_TENANT_2_OUTLET_ID=
# TCH_TENANT_2_TERMINAL_ID=
# TCH_TENANT_2_SELLER_USERNAME=
# TCH_TENANT_2_SELLER_PASSWORD=
# TCH_TENANT_2_STAKE_CENTS=200

# ── Tenant admin credentials (for onboarding tests) ───────────────────────────
# TCH_TENANT_ADMIN_USERNAME=
# TCH_TENANT_ADMIN_PASSWORD=

# ── Misc ──────────────────────────────────────────────────────────────────────
TCH_TEST_SLACK_CHANNEL_KEY=delivery
# TCH_ARTIFACT_DIR=
