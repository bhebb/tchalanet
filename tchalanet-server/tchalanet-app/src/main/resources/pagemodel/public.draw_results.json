{
  "code": "public.draw_results",
  "logical_id": "public.draw_results",
  "name": "Public draw results",
  "label": "Public draw results",
  "schema_version": 1,
  "schema": {},
  "is_default": true,
  "is_system": true,
  "description": "Page publique des résultats avec derniers résultats et recherche historique limitée.",
  "model": {
    "meta": {
      "id": "public.draw_results",
      "scope": "public",
      "slug": "results",
      "context": "public_draw_results",
      "schema_version": 1,
      "langs": [
        "fr",
        "en",
        "ht"
      ],
      "default_lang": "fr",
      "description": "Résultats publics par slot avec prochain tirage et historique limité."
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "header": {
        "component": "PublicHeader",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "file_key": "public_header_links",
          "show_search": true,
          "show_language": true,
          "show_theme_toggle": true
        }
      },
      "sidenav": null,
      "footer": {
        "component": "PublicFooter",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "file_key": "public_footer_links"
        }
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "results",
            "label_key": "layout.public_draw_results.results",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "public.draw_results.main"
                ]
              }
            ]
          }
        ]
      },
      "widgets": {
        "public.draw_results.main": {
          "type": "PublicDrawResultsPageWidget",
          "binding": {
            "mode": "dynamic",
            "source": "public_draw_results"
          },
          "props": {
            "title_key": "public_draw_results.title",
            "include_history": true,
            "history_limit": 10,
            "include_next_by_slot": true,
            "include_latest_by_slot": true,
            "show_filters": true
          }
        }
      }
    }
  }
}
