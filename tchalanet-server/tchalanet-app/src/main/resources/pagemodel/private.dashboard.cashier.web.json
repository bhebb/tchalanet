{
  "code": "private.dashboard.cashier.web",
  "logical_id": "private.dashboard.cashier.web",
  "name": "Cashier web dashboard",
  "label": "cashier web dashboard",
  "schema_version": 1,
  "schema": {},
  "is_default": true,
  "is_system": true,
  "description": "Tableau de bord cashier web — source unifiée cashier_dashboard (dashboard-overview-runtime-v1).",
  "model": {
    "meta": {
      "id": "private.dashboard.cashier.web",
      "scope": "private",
      "slug": "dashboard",
      "context": "private_dashboard_cashier",
      "schema_version": 1,
      "langs": ["fr", "en", "ht"],
      "default_lang": "fr",
      "description": "Dashboard web caissier — payload groupé via source cashier_dashboard."
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "header": {
        "component": "PrivateHeader",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "show_profile_menu": true,
          "file_key": "private_header_profile_menu"
        }
      },
      "sidenav": {
        "component": "PrivateSidenav",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "collapsible": true,
          "file_key": "private_sidebar_cashier"
        }
      },
      "footer": {
        "component": "PrivateFooter",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "file_key": "private_footer_links"
        }
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "identity",
            "label_key": "layout.private_dashboard_cashier.identity",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.identity"]
              }
            ]
          },
          {
            "id": "readiness",
            "label_key": "layout.private_dashboard_cashier.readiness",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.readiness", "dashboard.cashier.alerts"]
              }
            ]
          },
          {
            "id": "overview",
            "label_key": "layout.private_dashboard_cashier.overview",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.overview"]
              }
            ]
          },
          {
            "id": "quick_sale",
            "label_key": "layout.private_dashboard_cashier.quick_sale",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.quick_sale"]
              }
            ]
          },
          {
            "id": "recent_tickets",
            "label_key": "layout.private_dashboard_cashier.recent_tickets",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.recent_tickets"]
              }
            ]
          },
          {
            "id": "next_draws",
            "label_key": "layout.private_dashboard_cashier.next_draws",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.next_draws"]
              }
            ]
          },
          {
            "id": "session",
            "label_key": "layout.private_dashboard_cashier.session",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.session"]
              }
            ]
          }
        ]
      },
      "widgets": {
        "dashboard.cashier.identity": {
          "type": "CashierIdentityWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.identity.title"
          }
        },
        "dashboard.cashier.readiness": {
          "type": "OperationalReadinessWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.readiness.title"
          }
        },
        "dashboard.cashier.alerts": {
          "type": "AlertsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.alerts.title",
            "max_items": 5
          }
        },
        "dashboard.cashier.overview": {
          "type": "CashierOverviewWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.overview.title"
          }
        },
        "dashboard.cashier.quick_sale": {
          "type": "QuickSaleWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.quick_sale.title"
          }
        },
        "dashboard.cashier.recent_tickets": {
          "type": "RecentTicketsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.recent_tickets.title",
            "limit": 10
          }
        },
        "dashboard.cashier.next_draws": {
          "type": "NextDrawsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.next_draws.title",
            "limit": 10,
            "include_countdown": true
          }
        },
        "dashboard.cashier.session": {
          "type": "SessionSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.session.title"
          }
        },
        "dashboard.cashier.quick_actions": {
          "type": "QuickActionsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "json_file"
          },
          "props": {
            "title_key": "dashboard.cashier.quick_actions.title",
            "file_key": "private_cashier_quick_actions"
          }
        }
      }
    }
  }
}
