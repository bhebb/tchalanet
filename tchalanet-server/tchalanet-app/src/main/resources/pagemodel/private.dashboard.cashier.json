{
  "code": "private.dashboard.cashier",
  "logical_id": "private.dashboard.cashier",
  "name": "Cashier dashboard",
  "label": "cashier dashboard",
  "schema_version": 1,
  "schema": {},
  "is_default": true,
  "is_system": true,
  "description": "Dashboard web cashier V1: identité, readiness opérationnelle, session, prochains tirages, tickets récents et alertes.",
  "model": {
    "meta": {
      "id": "private.dashboard.cashier",
      "scope": "private",
      "slug": "dashboard",
      "context": "private_dashboard_cashier",
      "schema_version": 1,
      "langs": [
        "fr",
        "en",
        "ht"
      ],
      "default_lang": "fr",
      "description": "Dashboard web pour le caissier. POS/mobile utilise /tenant/cashier/home, pas ce PageModel."
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "header": {
        "component": "PrivateHeader",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "show_profile_menu": true,
          "file_key": "private_header_cashier"
        }
      },
      "sidenav": {
        "component": "PrivateSidenav",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "collapsible": true,
          "file_key": "private_sidebar_cashier"
        }
      },
      "footer": {
        "component": "PrivateFooter",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "file_key": "private_footer_links"
        }
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "identity",
            "label_key": "layout.private_dashboard_cashier.identity",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.cashier.identity"
                ]
              }
            ]
          },
          {
            "id": "readiness_session",
            "label_key": "layout.private_dashboard_cashier.readiness_session",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.cashier.readiness",
                  "dashboard.cashier.session"
                ]
              }
            ]
          },
          {
            "id": "sell_draws",
            "label_key": "layout.private_dashboard_cashier.sell_draws",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.cashier.primary_action",
                  "dashboard.cashier.next_draws"
                ]
              }
            ]
          },
          {
            "id": "recent_alerts",
            "label_key": "layout.private_dashboard_cashier.recent_alerts",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.cashier.recent_tickets",
                  "dashboard.cashier.alerts"
                ]
              }
            ]
          }
        ]
      },
      "widgets": {
        "dashboard.cashier.identity": {
          "type": "CashierIdentityWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.identity.title"
          }
        },
        "dashboard.cashier.readiness": {
          "type": "CashierReadinessWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.readiness.title"
          }
        },
        "dashboard.cashier.session": {
          "type": "SessionSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.session.title"
          }
        },
        "dashboard.cashier.primary_action": {
          "type": "PrimaryActionWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.primary_action.title"
          }
        },
        "dashboard.cashier.next_draws": {
          "type": "NextDrawsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.next_draws.title",
            "limit": 8,
            "include_countdown": true
          }
        },
        "dashboard.cashier.recent_tickets": {
          "type": "RecentTicketsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.recent_tickets.title",
            "limit": 10
          }
        },
        "dashboard.cashier.alerts": {
          "type": "CashierAlertsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "title_key": "dashboard.cashier.alerts.title",
            "max_items": 5
          }
        }
      }
    }
  }
}
