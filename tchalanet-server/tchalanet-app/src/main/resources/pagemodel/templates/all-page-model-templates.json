            },
            "props": {
              "file_key": "public_hero"
            }
          },
          "home.news": {
            "type": "NewsTickerWidget",
            "binding": {
              "mode": "dynamic",
              "source": "public_home"
            },
            "props": {
              "limit": 5,
              "title_key": "home.news.title",
              "show_dates": true
            }
          },
          "home.draws": {
            "type": "PublicDrawResultsWidget",
            "binding": {
              "mode": "dynamic",
              "source": "public_draw_results"
            },
            "props": {
              "max_slots": 6,
              "title_key": "home.draws.title",
              "moreDestination": {
                "id": "more_results",
                "type": "destination",
                "label_key": "nav.results",
                "label": null,
                "path": "/results",
                "kind": "internal",
                "icon": "emoji_events",
                "image": null,
                "active_match": "prefix",
                "disabled": false,
                "reason_key": null,
                "badge": null,
                "children": []
              },
              "history_limit": 0,
              "include_history": false,
              "include_next_by_slot": true,
              "include_latest_by_slot": true
            }
          },
          "home.plans": {
            "type": "PlansWidget",
            "binding": {
              "mode": "dynamic",
              "source": "public_home"
            },
            "props": {
              "items_key": "plans",
              "title_key": "home.plans.title",
              "demoDestination": {
                "id": "request_demo",
                "type": "destination",
                "label_key": "cta.request_demo",
                "label": null,
                "path": "/demo",
                "kind": "internal",
                "icon": "rocket_launch",
                "image": null,
                "active_match": "prefix",
                "disabled": false,
                "reason_key": null,
                "badge": null,
                "children": []
              },
              "show_toggle_billing_period": true
            }
          },
          "home.tchala": {
            "type": "TchalaSearchWidget",
            "binding": {
              "mode": "dynamic",
              "source": "json_file"
            },
            "props": {
              "file_key": "public_tchala"
            }
          },
          "home.features": {
            "type": "FeatureGridWidget",
            "binding": {
              "mode": "dynamic",
              "source": "json_file"
            },
            "props": {
              "layout": "LMSS",
              "file_key": "public_features"
            }
          },
          "home.check_ticket": {
            "type": "CheckTicketWidget",
            "binding": {
              "mode": "static"
            },
            "props": {
              "path": "/verifier",
              "cta_key": "cta.check_ticket",
              "title_key": "home.check_ticket.title",
              "description_key": "home.check_ticket.description"
            }
          }
        }
      }
    }
