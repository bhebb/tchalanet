{
  "code": "private.dashboard.superadmin",
  "logicalId": "private.dashboard.superadmin",
  "scope": "private",
  "slug": "dashboard",
  "name": "Superadmin dashboard",
  "label": "Superadmin dashboard",
  "schemaVersion": 2,
  "schema": {},
  "isDefault": true,
  "level": "GLOBAL",
  "tenantId": null,
  "description": "Superadmin dashboard V1: platform KPIs, alerts and quick actions (static binding).",
  "model": {
    "meta": {
      "id": "private.dashboard.superadmin",
      "scope": "private",
      "slug": "dashboard",
      "context": "private_dashboard_superadmin",
      "schemaVersion": 2,
      "langs": ["fr", "en", "ht"],
      "defaultLang": "fr"
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "component": "PrivateShell",
      "binding": {
        "mode": "dynamic",
        "source": "jsonFile"
      },
      "props": {
        "fileKey": "private_shell_superadmin"
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "kpis",
            "labelKey": "layout.private_dashboard_superadmin.kpis",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.superadmin.kpis"]
              }
            ]
          },
          {
            "id": "tenantsAlerts",
            "labelKey": "layout.private_dashboard_superadmin.tenants_alerts",
            "columns": [
              {
                "span": 6,
                "widgets": ["dashboard.superadmin.tenants"]
              },
              {
                "span": 6,
                "widgets": ["dashboard.superadmin.alerts"]
              }
            ]
          },
          {
            "id": "quickActions",
            "labelKey": "layout.private_dashboard_superadmin.quick_actions",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.superadmin.quickActions"]
              }
            ]
          }
        ]
      },
      "widgets": {
        "dashboard.superadmin.kpis": {
          "type": "KpiGridWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "dashboard.superadmin.kpis.title",
            "items": [
              { "id": "totalTenants", "labelKey": "platform.kpi.totalTenants.label", "icon": "apartment" },
              { "id": "activeTenants", "labelKey": "platform.kpi.activeTenants.label", "icon": "check_circle" },
              { "id": "activeSubscriptions", "labelKey": "platform.kpi.activeSubscriptions.label", "icon": "workspace_premium" },
              { "id": "pendingOnboarding", "labelKey": "platform.kpi.pendingOnboarding.label", "icon": "playlist_add_check" }
            ]
          }
        },
        "dashboard.superadmin.tenants": {
          "type": "KpiGridWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "dashboard.superadmin.tenants.title",
            "items": [
              { "id": "suspendedTenants", "labelKey": "platform.kpi.suspendedTenants.label", "icon": "block" },
              { "id": "tenantsWithIssues", "labelKey": "platform.kpi.tenantsWithIssues.label", "icon": "warning" }
            ]
          }
        },
        "dashboard.superadmin.alerts": {
          "type": "AlertsWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "dashboard.superadmin.alerts.title",
            "emptyKey": "dashboard.superadmin.alerts.empty"
          }
        },
        "dashboard.superadmin.quickActions": {
          "type": "QuickActionsWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "dashboard.superadmin.quick_actions.title",
            "actions": [
              {
                "id": "createTenant",
                "labelKey": "quickaction.platform.create_tenant",
                "icon": "add_business",
                "destination": { "kind": "route", "value": "/app/platform/tenants/new" }
              },
              {
                "id": "tenantOnboarding",
                "labelKey": "quickaction.platform.onboarding",
                "icon": "playlist_add_check",
                "destination": { "kind": "route", "value": "/app/platform/tenants/onboarding" }
              },
              {
                "id": "subscriptions",
                "labelKey": "quickaction.platform.subscriptions",
                "icon": "workspace_premium",
                "destination": { "kind": "route", "value": "/app/platform/subscriptions" }
              },
              {
                "id": "platformHealth",
                "labelKey": "quickaction.platform.platform_health",
                "icon": "monitor_heart",
                "destination": { "kind": "route", "value": "/app/platform/health" }
              },
              {
                "id": "drawResults",
                "labelKey": "quickaction.platform.draw_results",
                "icon": "fact_check",
                "destination": { "kind": "route", "value": "/app/platform/ops/draw-results" }
              }
            ]
          }
        }
      }
    }
  }
}
