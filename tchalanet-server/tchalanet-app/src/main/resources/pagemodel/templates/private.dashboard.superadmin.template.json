{
  "code": "private.dashboard.superadmin",
  "logicalId": "private.dashboard.superadmin",
  "scope": "private",
  "slug": "dashboard",
  "name": "Superadmin dashboard",
  "label": "superadmin dashboard",
  "schemaVersion": 2,
  "schema": {},
  "isDefault": true,
  "level": "GLOBAL",
  "tenantId": null,
  "description": "Dashboard global superadmin V1: santé plateforme, tenants, subscriptions, onboarding et alertes.",
  "model": {
    "meta": {
      "id": "private.dashboard.superadmin",
      "scope": "private",
      "slug": "dashboard",
      "context": "private_dashboard_superadmin",
      "schemaVersion": 2,
      "langs": [
        "fr",
        "en",
        "ht"
      ],
      "defaultLang": "fr"
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "component": "PrivateShell",
      "binding": {
        "mode": "dynamic",
        "source": "jsonFile"
      },
      "props": {
        "fileKey": "private_shell_super_admin"
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "health",
            "labelKey": "layout.private_dashboard_superadmin.health",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.superadmin.health"
                ]
              }
            ]
          },
          {
            "id": "tenantKpis",
            "labelKey": "layout.private_dashboard_superadmin.tenant_kpis",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.superadmin.tenants",
                  "dashboard.superadmin.subscriptions"
                ]
              }
            ]
          },
          {
            "id": "onboardingAlerts",
            "labelKey": "layout.private_dashboard_superadmin.onboarding_alerts",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.superadmin.onboarding",
                  "dashboard.superadmin.alerts"
                ]
              }
            ]
          },
          {
            "id": "quickActions",
            "labelKey": "layout.private_dashboard_superadmin.quick_actions",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.superadmin.quick_actions"
                ]
              }
            ]
          }
        ]
      },
      "widgets": {
        "dashboard.superadmin.health": {
          "type": "PlatformHealthWidget",
          "binding": {
            "mode": "dynamic",
            "source": "platform_admin_dashboard"
          },
          "props": {
            "titleKey": "dashboard.superadmin.health.title"
          }
        },
        "dashboard.superadmin.tenants": {
          "type": "TenantKpiSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "platform_admin_dashboard"
          },
          "props": {
            "titleKey": "dashboard.superadmin.tenants.title"
          }
        },
        "dashboard.superadmin.subscriptions": {
          "type": "SubscriptionSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "platform_admin_dashboard"
          },
          "props": {
            "titleKey": "dashboard.superadmin.subscriptions.title"
          }
        },
        "dashboard.superadmin.onboarding": {
          "type": "TenantOnboardingAlertsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "platform_admin_dashboard"
          },
          "props": {
            "maxItems": 5,
            "titleKey": "dashboard.superadmin.onboarding.title"
          }
        },
        "dashboard.superadmin.alerts": {
          "type": "PlatformAlertsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "platform_admin_dashboard"
          },
          "props": {
            "maxItems": 5,
            "titleKey": "dashboard.superadmin.alerts.title"
          }
        },
        "dashboard.superadmin.quick_actions": {
          "type": "QuickActionsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "platform_admin_dashboard"
          },
          "props": {
            "titleKey": "dashboard.superadmin.quick_actions.title"
          }
        }
      }
    }
  }
}
