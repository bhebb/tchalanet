              },
              "icon": "menu_book",
              "image": null,
              "activeMatch": null,
              "disabled": false,
              "reasonKey": null,
              "badge": null,
              "children": []
            }
          }
        },
        "home.contactCta": {
          "type": "ContactCtaWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "public.contact_cta.title",
            "bodyKey": "public.contact_cta.body",
            "primaryAction": {
              "id": "requestDemo",
              "kind": "link",
              "labelKey": "public.contact_cta.cta",
              "label": null,
              "destination": {
                "kind": "route",
                "value": "/public/contact"
              },
              "icon": "rocket_launch",
              "image": null,
              "activeMatch": null,
              "disabled": false,
              "reasonKey": null,
              "badge": null,
              "children": []
            },
            "helpAction": {
              "id": "goToHelp",
              "kind": "link",
