          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "public.rules.title",
            "descriptionKey": "public.rules.subtitle",
            "ctaNoteKey": "public.rules.cta_note",
            "primaryAction": {
              "id": "viewRules",
              "kind": "link",
              "labelKey": "public.rules.cta_rules",
              "label": null,
              "destination": {
                "kind": "route",
