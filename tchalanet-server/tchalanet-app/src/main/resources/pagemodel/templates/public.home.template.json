{
  "code": "public.home",
  "logicalId": "public.home",
  "scope": "public",
  "slug": "home",
  "name": "Public home",
  "label": "public home",
  "schemaVersion": 2,
  "schema": {},
  "isDefault": true,
  "level": "GLOBAL",
  "tenantId": null,
  "description": "Public home PageModel V2: hero, how it works, news, public draw results, ticket verification, Tchala, features, rules, plans and operator CTA.",
  "model": {
    "meta": {
      "id": "public.home",
      "scope": "public",
      "slug": "home",
      "context": "public_home",
      "schemaVersion": 2,
      "langs": [
        "fr",
        "en",
        "ht"
      ],
      "defaultLang": "fr"
    },
    "theme": {
      "presetId": "tchalanet",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "header": {
        "component": "PublicHeader",
        "binding": {
          "mode": "dynamic",
          "source": "jsonfile"
        },
        "props": {
          "fileKey": "public_header_links"
        }
      },
      "footer": {
        "component": "PublicFooter",
        "binding": {
          "mode": "dynamic",
          "source": "jsonfile"
        },
        "props": {
          "fileKey": "public_footer_links"
        }
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "hero",
            "labelKey": "layout.public_home.hero",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "home.hero"
                ]
              }
            ]
          },
          {
            "id": "draws",
            "labelKey": "layout.public_home.draws",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "home.draws"
                ]
              }
            ]
          },
          {
            "id": "howItWorks",
            "labelKey": "layout.public_home.how_it_works",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "home.howItWorks"
                ]
              }
            ]
          },
          {
            "id": "ticketVerification",
            "labelKey": "layout.public_home.ticket_verification",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "home.checkTicket"
                ]
              }
            ]
          },
          {
            "id": "operatorCta",
            "labelKey": "layout.public_home.operator_cta",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "home.operatorCta"
                ]
              }
            ]
          },
          {
            "id": "news",
            "labelKey": "layout.public_home.news",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "home.news"
                ]
              }
            ]
          },
          {
            "id": "tchala",
            "labelKey": "layout.public_home.tchala",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "home.tchala"
                ]
              }
            ]
          },
          {
            "id": "rules",
            "labelKey": "layout.public_home.rules",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "home.rules"
                ]
              }
            ]
          }
        ]
      },
      "widgets": {
        "home.hero": {
          "type": "HeroWidget",
          "binding": {
            "mode": "dynamic",
            "source": "jsonFile"
          },
          "props": {
            "fileKey": "public_hero"
          }
        },
        "home.draws": {
          "type": "PublicDrawResultsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "public_draw_results"
          },
          "props": {
            "maxSlots": 6,
            "titleKey": "home.draws.title",
            "moreDestination": {
              "id": "moreResults",
              "kind": "link",
              "labelKey": "public.nav.results",
              "label": null,
              "destination": {
                "kind": "route",
                "value": "/public/results"
              },
              "icon": "emoji_events",
              "image": null,
              "activeMatch": "prefix",
              "disabled": false,
              "reasonKey": null,
              "badge": null,
              "children": []
            },
            "historyLimit": 0,
            "includeHistory": false,
            "includeNextBySlot": true,
            "includeLatestBySlot": true
          }
        },
        "home.howItWorks": {
          "type": "HowItWorksWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "public.how.title",
            "descriptionKey": "public.how.description",
            "steps": [
              {
                "titleKey": "public.how.step1.title",
                "textKey": "public.how.step1.text"
              },
              {
                "titleKey": "public.how.step2.title",
                "textKey": "public.how.step2.text"
              },
              {
                "titleKey": "public.how.step3.title",
                "textKey": "public.how.step3.text"
              },
              {
                "titleKey": "public.how.step4.title",
                "textKey": "public.how.step4.text"
              }
            ]
          }
        },
        "home.checkTicket": {
          "type": "TicketVerificationWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "path": "/public/check-ticket",
            "ctaKey": "public.ticket.cta",
            "titleKey": "home.check_ticket.title",
            "descriptionKey": "home.check_ticket.description"
          }
        },
        "home.operatorCta": {
          "type": "OperatorCtaWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "public.operator.title",
            "descriptionKey": "public.operator.description",
            "primaryAction": {
              "id": "requestDemo",
              "kind": "button",
              "labelKey": "public.operator.demo",
              "label": null,
              "destination": {
                "kind": "route",
                "value": "/public/contact"
              },
              "icon": "rocket_launch",
              "image": null,
              "activeMatch": null,
              "disabled": false,
              "reasonKey": null,
              "badge": null,
              "children": []
            },
            "secondaryAction": {
              "id": "operatorAccess",
              "kind": "link",
              "labelKey": "public.operator.access",
              "label": null,
              "destination": {
                "kind": "route",
                "value": "/login"
              },
              "icon": "login",
              "image": null,
              "activeMatch": null,
              "disabled": false,
              "reasonKey": null,
              "badge": null,
              "children": []
            }
          }
        },
        "home.news": {
          "type": "NewsTickerWidget",
          "binding": {
            "mode": "dynamic",
            "source": "public_home"
          },
          "props": {
            "limit": 5,
            "titleKey": "home.news.title",
            "showDates": true
          }
        },
        "home.tchala": {
          "type": "TchalaSearchWidget",
          "binding": {
            "mode": "dynamic",
            "source": "jsonFile"
          },
          "props": {
            "fileKey": "public_tchala"
          }
        },
        "home.rules": {
          "type": "RulesWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "public.rules.title",
            "descriptionKey": "public.rules.subtitle"
          }
        }
      }
    }
  }
}
