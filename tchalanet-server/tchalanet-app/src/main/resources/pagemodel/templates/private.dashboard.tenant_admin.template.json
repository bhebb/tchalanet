{
  "code": "private.dashboard.tenant_admin",
  "logical_id": "private.dashboard.tenant_admin",
  "scope": "private",
  "slug": "dashboard",
  "name": "Tenant admin dashboard",
  "label": "tenant admin dashboard",
  "schema_version": 2,
  "schema": {},
  "is_default": true,
  "level": "GLOBAL",
  "tenant_id": null,
  "description": "Tenant admin dashboard V1: tenant KPIs, readiness, alerts, operations summary, commercial summary and quick actions.",
  "model": {
    "meta": {
      "id": "private.dashboard.tenant_admin",
      "scope": "private",
      "slug": "dashboard",
      "context": "private_dashboard_tenant_admin",
      "schema_version": 2,
      "langs": [
        "fr",
        "en",
        "ht"
      ],
      "default_lang": "fr"
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "header": {
        "component": "PrivateShell",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "file_key": "private_shell_tenant_admin"
        }
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "header",
            "label_key": "layout.dashboard.tenant_admin.header",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.tenant_admin.header"
                ]
              }
            ]
          },
          {
            "id": "kpis",
            "label_key": "layout.dashboard.tenant_admin.kpis",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.tenant_admin.kpis"
                ]
              }
            ]
          },
          {
            "id": "readiness_alerts",
            "label_key": "layout.dashboard.tenant_admin.readiness_alerts",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.tenant_admin.readiness",
                  "dashboard.tenant_admin.alerts"
                ]
              }
            ]
          },
          {
            "id": "summaries",
            "label_key": "layout.dashboard.tenant_admin.summaries",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.tenant_admin.operations",
                  "dashboard.tenant_admin.commercial"
                ]
              }
            ]
          },
          {
            "id": "quick_actions",
            "label_key": "layout.dashboard.tenant_admin.quick_actions",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.tenant_admin.quick_actions"
                ]
              }
            ]
          }
        ]
      },
      "widgets": {
        "dashboard.tenant_admin.kpis": {
          "type": "KpiGridWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "items": [
              "salesToday",
              "ticketCountToday",
              "activeSessions",
              "openDraws",
              "pendingApprovals"
            ],
            "title_key": "dashboard.tenant_admin.kpis.title"
          }
        },
        "dashboard.tenant_admin.alerts": {
          "type": "AlertsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "max_items": 5,
            "title_key": "dashboard.tenant_admin.alerts.title"
          }
        },
        "dashboard.tenant_admin.header": {
          "type": "TenantDashboardHeaderWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "title_key": "dashboard.tenant_admin.header.title"
          }
        },
        "dashboard.tenant_admin.readiness": {
          "type": "ReadinessSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "title_key": "dashboard.tenant_admin.readiness.title",
            "max_issues": 4
          }
        },
        "dashboard.tenant_admin.commercial": {
          "type": "CommercialSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "sections": [
              "gamesPricing",
              "drawChannels",
              "limits",
              "promotions"
            ],
            "title_key": "dashboard.tenant_admin.commercial.title"
          }
        },
        "dashboard.tenant_admin.operations": {
          "type": "OperationsSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "sections": [
              "users",
              "outlets",
              "terminals",
              "sessions"
            ],
            "title_key": "dashboard.tenant_admin.operations.title"
          }
        },
        "dashboard.tenant_admin.quick_actions": {
          "type": "QuickActionsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "title_key": "dashboard.tenant_admin.quick_actions.title"
          }
        }
      }
    }
  }
}