{
  "code": "private.dashboard.tenant_admin",
  "logicalId": "private.dashboard.tenant_admin",
  "scope": "private",
  "slug": "dashboard",
  "name": "Tenant admin dashboard",
  "label": "Tenant admin dashboard",
  "schemaVersion": 2,
  "schema": {},
  "isDefault": true,
  "level": "GLOBAL",
  "tenantId": null,
  "description": "Tenant admin dashboard V1: KPIs, readiness, alerts and quick actions (dynamic binding, seller_terminal model).",
  "model": {
    "meta": {
      "id": "private.dashboard.tenant_admin",
      "scope": "private",
      "slug": "dashboard",
      "context": "private_dashboard_tenant_admin",
      "schemaVersion": 2,
      "langs": ["fr", "en", "ht"],
      "defaultLang": "fr"
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "component": "PrivateShell",
      "binding": {
        "mode": "dynamic",
        "source": "jsonFile"
      },
      "props": {
        "fileKey": "private_shell_tenant_admin"
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "kpis",
            "labelKey": "layout.dashboard.tenant_admin.kpis",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.tenantAdmin.kpis"]
              }
            ]
          },
          {
            "id": "readinessAlerts",
            "labelKey": "layout.dashboard.tenant_admin.readiness_alerts",
            "columns": [
              {
                "span": 6,
                "widgets": ["dashboard.tenantAdmin.readiness"]
              },
              {
                "span": 6,
                "widgets": ["dashboard.tenantAdmin.alerts"]
              }
            ]
          },
          {
            "id": "salesInsights",
            "labelKey": "layout.dashboard.tenant_admin.sales_insights",
            "columns": [
              {
                "span": 7,
                "widgets": ["dashboard.tenantAdmin.salesTrend"]
              },
              {
                "span": 5,
                "widgets": ["dashboard.tenantAdmin.gameBreakdown"]
              }
            ]
          },
          {
            "id": "commission",
            "labelKey": "layout.dashboard.tenant_admin.commission",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.tenantAdmin.commission"]
              }
            ]
          },
          {
            "id": "quickActions",
            "labelKey": "layout.dashboard.tenant_admin.quick_actions",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.tenantAdmin.quickActions"]
              }
            ]
          }
        ]
      },
      "widgets": {
        "dashboard.tenantAdmin.kpis": {
          "type": "KpiGridWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "titleKey": "dashboard.tenant_admin.kpis.title",
            "items": [
              { "id": "salesToday",            "labelKey": "admin.kpi.sales_today.label",             "icon": "payments",        "tone": "accent"  },
              { "id": "activeSellerTerminals", "labelKey": "admin.kpi.active_seller_terminals.label", "icon": "point_of_sale",  "tone": "success" },
              { "id": "winningsToday",         "labelKey": "admin.kpi.payout_due.label",              "icon": "account_balance","tone": "warning" },
              { "id": "notificationCount",     "labelKey": "admin.kpi.notifications.label",           "icon": "notifications",  "tone": "primary" }
            ]
          }
        },
        "dashboard.tenantAdmin.readiness": {
          "type": "ReadinessSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "titleKey": "dashboard.tenant_admin.readiness.title"
          }
        },
        "dashboard.tenantAdmin.alerts": {
          "type": "AlertsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "titleKey": "dashboard.tenant_admin.alerts.title",
            "emptyKey": "dashboard.tenant_admin.alerts.empty"
          }
        },
        "dashboard.tenantAdmin.salesTrend": {
          "type": "TrendChartWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "titleKey": "dashboard.tenant_admin.sales_trend.title",
            "emptyKey": "dashboard.tenant_admin.sales_trend.empty",
            "points": { "source": "dynamic", "path": "points" },
            "labelPath": "label",
            "labelFormat": "date-short",
            "valuePath": "grossSales"
          }
        },
        "dashboard.tenantAdmin.gameBreakdown": {
          "type": "BreakdownListWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "titleKey": "dashboard.tenant_admin.game_breakdown.title",
            "emptyKey": "dashboard.tenant_admin.game_breakdown.empty",
            "items": { "source": "dynamic", "path": "items" },
            "labelPath": "label",
            "valuePath": "grossSales",
            "valueFormat": "currency",
            "currencyCode": "HTG"
          }
        },
        "dashboard.tenantAdmin.commission": {
          "type": "CommissionSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "titleKey": "dashboard.tenant_admin.commission.title",
            "manageLink": "/app/admin/controls/commission"
          }
        },
        "dashboard.tenantAdmin.quickActions": {
          "type": "QuickActionsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "tenant_admin_dashboard"
          },
          "props": {
            "titleKey": "dashboard.tenant_admin.quick_actions.title",
            "actions": [
              {
                "id": "addSellerTerminal",
                "labelKey": "quickaction.admin.add_seller_terminal",
                "icon": "person_add",
                "destination": { "kind": "route", "value": "/app/admin/sellers/new" }
              },
              {
                "id": "activeSellerTerminals",
                "labelKey": "quickaction.admin.active_seller_terminals",
                "icon": "point_of_sale",
                "destination": { "kind": "route", "value": "/app/admin/sellers?status=active" }
              },
              {
                "id": "dailyReport",
                "labelKey": "quickaction.admin.daily_report",
                "icon": "today",
                "destination": { "kind": "route", "value": "/app/admin/reports/today" }
              },
              {
                "id": "manageLimits",
                "labelKey": "quickaction.admin.manage_limits",
                "icon": "shield",
                "destination": { "kind": "route", "value": "/app/admin/controls/limits" }
              },
              {
                "id": "manageOdds",
                "labelKey": "quickaction.admin.manage_odds",
                "icon": "percent",
                "destination": { "kind": "route", "value": "/app/admin/controls/odds" }
              },
              {
                "id": "maryajGratis",
                "labelKey": "quickaction.admin.maryaj_gratis",
                "icon": "redeem",
                "destination": { "kind": "route", "value": "/app/admin/promotions/maryaj-gratis" }
              }
            ]
          }
        }
      }
    }
  }
}
