{
  "code": "private.dashboard.tenant_admin",
  "logicalId": "private.dashboard.tenant_admin",
  "scope": "private",
  "slug": "dashboard",
  "name": "Tenant admin dashboard",
  "label": "Tenant admin dashboard",
  "schemaVersion": 2,
  "schema": {},
  "isDefault": true,
  "level": "GLOBAL",
  "tenantId": null,
  "description": "Tenant admin dashboard V1: KPIs, readiness, alerts and quick actions (static binding).",
  "model": {
    "meta": {
      "id": "private.dashboard.tenant_admin",
      "scope": "private",
      "slug": "dashboard",
      "context": "private_dashboard_tenant_admin",
      "schemaVersion": 2,
      "langs": ["fr", "en", "ht"],
      "defaultLang": "fr"
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "component": "PrivateShell",
      "binding": {
        "mode": "dynamic",
        "source": "jsonFile"
      },
      "props": {
        "fileKey": "private_shell_tenant_admin"
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "kpis",
            "labelKey": "layout.dashboard.tenant_admin.kpis",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.tenantAdmin.kpis"]
              }
            ]
          },
          {
            "id": "readinessAlerts",
            "labelKey": "layout.dashboard.tenant_admin.readiness_alerts",
            "columns": [
              {
                "span": 6,
                "widgets": ["dashboard.tenantAdmin.readiness"]
              },
              {
                "span": 6,
                "widgets": ["dashboard.tenantAdmin.alerts"]
              }
            ]
          },
          {
            "id": "quickActions",
            "labelKey": "layout.dashboard.tenant_admin.quick_actions",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.tenantAdmin.quickActions"]
              }
            ]
          }
        ]
      },
      "widgets": {
        "dashboard.tenantAdmin.kpis": {
          "type": "KpiGridWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "dashboard.tenant_admin.kpis.title",
            "items": [
              { "id": "sellers", "labelKey": "admin.kpi.sellers.label", "icon": "person_pin" },
              { "id": "outlets", "labelKey": "admin.kpi.outlets.label", "icon": "storefront" },
              { "id": "terminals", "labelKey": "admin.kpi.terminals.label", "icon": "point_of_sale" },
              { "id": "openSessions", "labelKey": "admin.kpi.openSessions.label", "icon": "account_balance_wallet" }
            ]
          }
        },
        "dashboard.tenantAdmin.readiness": {
          "type": "ReadinessSummaryWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "dashboard.tenant_admin.readiness.title"
          }
        },
        "dashboard.tenantAdmin.alerts": {
          "type": "AlertsWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "dashboard.tenant_admin.alerts.title",
            "emptyKey": "dashboard.tenant_admin.alerts.empty"
          }
        },
        "dashboard.tenantAdmin.quickActions": {
          "type": "QuickActionsWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "dashboard.tenant_admin.quick_actions.title",
            "actions": [
              {
                "id": "users",
                "labelKey": "admin.action.users",
                "icon": "group",
                "destination": { "kind": "route", "value": "/app/admin/users" }
              },
              {
                "id": "outlets",
                "labelKey": "admin.action.outlets",
                "icon": "storefront",
                "destination": { "kind": "route", "value": "/app/admin/outlets" }
              },
              {
                "id": "terminals",
                "labelKey": "admin.action.terminals",
                "icon": "point_of_sale",
                "destination": { "kind": "route", "value": "/app/admin/terminals" }
              },
              {
                "id": "sessions",
                "labelKey": "admin.action.sessions",
                "icon": "account_balance_wallet",
                "destination": { "kind": "route", "value": "/app/admin/sessions" }
              },
              {
                "id": "settings",
                "labelKey": "admin.action.settings",
                "icon": "settings",
                "destination": { "kind": "route", "value": "/app/admin/settings" }
              }
            ]
          }
        }
      }
    }
  }
}
