{
  "code": "private.dashboard.cashier.web",
  "logicalId": "private.dashboard.cashier.web",
  "scope": "private",
  "slug": "dashboard",
  "name": "Cashier dashboard",
  "label": "cashier dashboard",
  "schemaVersion": 2,
  "schema": {},
  "isDefault": true,
  "level": "GLOBAL",
  "tenantId": null,
  "description": "Operational cashier dashboard V1: identity, readiness, alerts, sales overview, quick sale, recent tickets, next draws and session.",
  "model": {
    "meta": {
      "id": "private.dashboard.cashier.web",
      "scope": "private",
      "slug": "dashboard",
      "context": "private_dashboard_cashier",
      "schemaVersion": 2,
      "langs": [
        "fr",
        "en",
        "ht"
      ],
      "defaultLang": "fr"
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "component": "PrivateShell",
      "binding": {
        "mode": "dynamic",
        "source": "jsonFile"
      },
      "props": {
        "fileKey": "private_shell_cashier"
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "identity",
            "labelKey": "layout.private_dashboard_cashier.identity",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.cashier.identity"
                ]
              }
            ]
          },
          {
            "id": "readiness",
            "labelKey": "layout.private_dashboard_cashier.readiness",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.cashier.readiness",
                  "dashboard.cashier.alerts"
                ]
              }
            ]
          },
          {
            "id": "overview",
            "labelKey": "layout.private_dashboard_cashier.overview",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.cashier.overview"
                ]
              }
            ]
          },
          {
            "id": "quickSale",
            "labelKey": "layout.private_dashboard_cashier.quick_sale",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.cashier.quickSale"
                ]
              }
            ]
          },
          {
            "id": "quickActions",
            "labelKey": "layout.private_dashboard_cashier.quick_actions",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.cashier.quickActions"
                ]
              }
            ]
          },
          {
            "id": "recentTickets",
            "labelKey": "layout.private_dashboard_cashier.recent_tickets",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.cashier.recentTickets"
                ]
              }
            ]
          },
          {
            "id": "nextDraws",
            "labelKey": "layout.private_dashboard_cashier.next_draws",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.cashier.nextDraws"
                ]
              }
            ]
          },
          {
            "id": "session",
            "labelKey": "layout.private_dashboard_cashier.session",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.cashier.session"
                ]
              }
            ]
          }
        ]
      },
      "widgets": {
        "dashboard.cashier.identity": {
          "type": "CashierIdentityWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "titleKey": "dashboard.cashier.identity.title"
          }
        },
        "dashboard.cashier.readiness": {
          "type": "OperationalReadinessWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "titleKey": "dashboard.cashier.readiness.title"
          }
        },
        "dashboard.cashier.alerts": {
          "type": "AlertsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "maxItems": 5,
            "titleKey": "dashboard.cashier.alerts.title"
          }
        },
        "dashboard.cashier.overview": {
          "type": "CashierOverviewWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "titleKey": "dashboard.cashier.overview.title"
          }
        },
        "dashboard.cashier.quickSale": {
          "type": "QuickSaleWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "titleKey": "dashboard.cashier.quick_sale.title"
          }
        },
        "dashboard.cashier.quickActions": {
          "type": "QuickActionsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "jsonFile"
          },
          "props": {
            "fileKey": "private_cashier_quick_actions",
            "titleKey": "dashboard.cashier.quick_actions.title"
          }
        },
        "dashboard.cashier.recentTickets": {
          "type": "RecentTicketsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "limit": 10,
            "titleKey": "dashboard.cashier.recent_tickets.title"
          }
        },
        "dashboard.cashier.nextDraws": {
          "type": "NextDrawsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "limit": 10,
            "titleKey": "dashboard.cashier.next_draws.title",
            "includeCountdown": true
          }
        },
        "dashboard.cashier.session": {
          "type": "SessionSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_dashboard"
          },
          "props": {
            "titleKey": "dashboard.cashier.session.title"
          }
        }
      }
    }
  }
}
