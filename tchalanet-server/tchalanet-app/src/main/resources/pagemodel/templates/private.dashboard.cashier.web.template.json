{
  "code": "private.dashboard.cashier.web",
  "logicalId": "private.dashboard.cashier.web",
  "scope": "private",
  "slug": "dashboard",
  "name": "Cashier dashboard",
  "label": "Cashier dashboard",
  "schemaVersion": 2,
  "schema": {},
  "isDefault": true,
  "level": "GLOBAL",
  "tenantId": null,
  "description": "Cashier dashboard V1: readiness, alerts and quick sale actions (static binding).",
  "model": {
    "meta": {
      "id": "private.dashboard.cashier.web",
      "scope": "private",
      "slug": "dashboard",
      "context": "private_dashboard_cashier",
      "schemaVersion": 2,
      "langs": ["fr", "en", "ht"],
      "defaultLang": "fr"
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "component": "PrivateShell",
      "binding": {
        "mode": "dynamic",
        "source": "jsonFile"
      },
      "props": {
        "fileKey": "private_shell_cashier"
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "readinessAlerts",
            "labelKey": "layout.private_dashboard_cashier.readiness_alerts",
            "columns": [
              {
                "span": 6,
                "widgets": ["dashboard.cashier.readiness"]
              },
              {
                "span": 6,
                "widgets": ["dashboard.cashier.alerts"]
              }
            ]
          },
          {
            "id": "quickActions",
            "labelKey": "layout.private_dashboard_cashier.quick_actions",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.quickActions"]
              }
            ]
          }
        ]
      },
      "widgets": {
        "dashboard.cashier.readiness": {
          "type": "ReadinessSummaryWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "dashboard.cashier.readiness.title"
          }
        },
        "dashboard.cashier.alerts": {
          "type": "AlertsWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "dashboard.cashier.alerts.title",
            "emptyKey": "dashboard.cashier.alerts.empty"
          }
        },
        "dashboard.cashier.quickActions": {
          "type": "QuickActionsWidget",
          "binding": {
            "mode": "static"
          },
          "props": {
            "titleKey": "dashboard.cashier.quick_actions.title",
            "actions": [
              {
                "id": "sellTicket",
                "labelKey": "cta.sell_ticket",
                "icon": "point_of_sale",
                "destination": { "kind": "route", "value": "/app/cashier/sale" }
              },
              {
                "id": "verifyTicket",
                "labelKey": "cta.verify_ticket",
                "icon": "qr_code_scanner",
                "destination": { "kind": "route", "value": "/app/cashier/tickets/verify" }
              },
              {
                "id": "closeSession",
                "labelKey": "cta.close_session",
                "icon": "account_balance_wallet",
                "destination": { "kind": "route", "value": "/app/cashier/session" }
              }
            ]
          }
        }
      }
    }
  }
}
