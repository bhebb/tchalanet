{
  "code": "private.dashboard.superadmin",
  "logical_id": "private.dashboard.superadmin",
  "name": "Superadmin dashboard",
  "label": "superadmin dashboard",
  "schema_version": 1,
  "schema": {},
  "is_default": true,
  "is_system": true,
  "description": "Dashboard global superadmin V1: santé plateforme, tenants, subscriptions, onboarding et alertes.",
  "model": {
    "meta": {
      "id": "private.dashboard.superadmin",
      "scope": "private",
      "slug": "dashboard",
      "context": "private_dashboard_superadmin",
      "schema_version": 1,
      "langs": [
        "fr",
        "en",
        "ht"
      ],
      "default_lang": "fr",
      "description": "Dashboard superadmin: KPI plateforme, santé système, onboarding tenants et alertes."
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "header": {
        "component": "PrivateShell",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "file_key": "private_shell_superadmin"
        }
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "health",
            "label_key": "layout.private_dashboard_superadmin.health",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.superadmin.health"
                ]
              }
            ]
          },
          {
            "id": "tenant_kpis",
            "label_key": "layout.private_dashboard_superadmin.tenant_kpis",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.superadmin.tenants",
                  "dashboard.superadmin.subscriptions"
                ]
              }
            ]
          },
          {
            "id": "onboarding_alerts",
            "label_key": "layout.private_dashboard_superadmin.onboarding_alerts",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.superadmin.onboarding",
                  "dashboard.superadmin.alerts"
                ]
              }
            ]
          },
          {
            "id": "quick_actions",
            "label_key": "layout.private_dashboard_superadmin.quick_actions",
            "columns": [
              {
                "span": 12,
                "widgets": [
                  "dashboard.superadmin.quick_actions"
                ]
              }
            ]
          }
        ]
      },
      "widgets": {
        "dashboard.superadmin.health": {
          "type": "PlatformHealthWidget",
          "binding": {
            "mode": "dynamic",
            "source": "platform_admin_dashboard"
          },
          "props": {
            "title_key": "dashboard.superadmin.health.title"
          }
        },
        "dashboard.superadmin.tenants": {
          "type": "TenantKpiSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "platform_admin_dashboard"
          },
          "props": {
            "title_key": "dashboard.superadmin.tenants.title"
          }
        },
        "dashboard.superadmin.subscriptions": {
          "type": "SubscriptionSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "platform_admin_dashboard"
          },
          "props": {
            "title_key": "dashboard.superadmin.subscriptions.title"
          }
        },
        "dashboard.superadmin.onboarding": {
          "type": "TenantOnboardingAlertsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "platform_admin_dashboard"
          },
          "props": {
            "title_key": "dashboard.superadmin.onboarding.title",
            "max_items": 5
          }
        },
        "dashboard.superadmin.alerts": {
          "type": "PlatformAlertsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "platform_admin_dashboard"
          },
          "props": {
            "title_key": "dashboard.superadmin.alerts.title",
            "max_items": 5
          }
        },
        "dashboard.superadmin.quick_actions": {
          "type": "QuickActionsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "platform_admin_dashboard"
          },
          "props": {
            "title_key": "dashboard.superadmin.quick_actions.title"
          }
        }
      }
    }
  }
}
