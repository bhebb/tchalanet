{
  "currentLang": "fr",
  "langs": ["fr", "en", "ht"],
  "context": "home-cashier",
  "theme": {
    "presetId": "tchalanet",
    "mode": "light",
    "density": -1,
    "overrides": { "vars": {} }
  },
  "header": {
    "component": "PrivateHeader",
    "properties": {
      "brand": {
        "logo": "/assets/branding/logo-tchalanet.svg",
        "name": "Tchalanet",
        "href": "/app/pos"
      },
      "navigation": [
        { "labelKey": "nav.pos", "path": "/app/pos" },
        { "labelKey": "nav.sales", "path": "/app/sales" },
        { "labelKey": "nav.results", "path": "/app/results" }
      ]
    }
  },
  "nav": {
    "header": [],
    "sidenav": [
      {
        "labelKey": "nav.pos",
        "path": "/app/pos",
        "icon": "point_of_sale"
      },
      {
        "labelKey": "nav.sales",
        "path": "/app/sales",
        "icon": "receipt_long",
        "children": [
          {
            "labelKey": "nav.sales.today",
            "path": "/app/sales/today",
            "icon": "today"
          },
          {
            "labelKey": "nav.sales.history",
            "path": "/app/sales/history",
            "icon": "history"
          }
        ]
      },
      {
        "labelKey": "nav.results",
        "path": "/app/results",
        "icon": "insights",
        "children": [
          {
            "labelKey": "nav.results.latest",
            "path": "/app/results/latest",
            "icon": "new_releases"
          },
          {
            "labelKey": "nav.results.archive",
            "path": "/app/results/archive",
            "icon": "archive"
          }
        ]
      }
    ]
  },
  "layout": {
    "component": "GridLayout",
    "rows": [
      {
        "columns": [
          {
            "span": 12,
            "widgets": [
              {
                "component": "HeroWidget",
                "properties": {
                  "eyebrow": "home.cashier.eyebrow",
                  "title": "home.cashier.title",
                  "subtitle": "home.cashier.subtitle",
                  "align": "left"
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "component": "PublicFooter",
    "properties": {
      "brand": {
        "logo": "/assets/branding/logo-tchalanet.svg",
        "name": "Tchalanet",
        "href": "/"
      },
      "accentHex": "#D84C51",
      "columns": [
        {
          "titleKey": "footer.section.inform",
          "links": [
            { "labelKey": "info.game_explanations", "path": "/explanations" },
            { "labelKey": "info.security_tips", "path": "/security" },
            { "labelKey": "info.official_results", "path": "/official-reports" },
            { "labelKey": "info.tchala", "path": "/tchala" }
          ]
        },
        {
          "titleKey": "footer.section.legal",
          "links": [
            { "labelKey": "legal.regulation", "path": "/legal/regulation" },
            { "labelKey": "legal.responsible", "path": "/legal/responsible" },
            { "labelKey": "legal.privacy", "path": "/legal/privacy" }
          ]
        },
        {
          "titleKey": "footer.section.resources",
          "links": [
            { "labelKey": "nav.verify", "path": "/verify" },
            { "labelKey": "nav.support", "path": "/support" }
          ]
        },
        {
          "titleKey": "footer.section.partners",
          "links": [
            { "labelKey": "partners.antb", "external": "https://antbhaiti.org" },
            { "labelKey": "partners.evalujeu", "external": "https://www.evalujeu.fr/" }
          ]
        }
      ],
      "socials": [
        { "icon": "youtube", "href": "https://youtube.com/@tchalanet", "aria": "YouTube" },
        { "icon": "x", "href": "https://x.com/tchalanet", "aria": "x" },
        { "icon": "facebook", "href": "https://facebook.com/tchalanet", "aria": "Facebook" },
        { "icon": "instagram", "href": "https://instagram.com/tchalanet", "aria": "Instagram" },
        { "icon": "linkedin", "href": "https://linkedin.com/company/tchalanet", "aria": "LinkedIn" }
      ],
      "copyrightKey": "copyright.notice"
    }
  },
  "i18n": {},
  "issues": []
}
