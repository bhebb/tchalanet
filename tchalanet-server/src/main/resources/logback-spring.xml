<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <!-- Read Spring Boot / application.yml logging.level.* into logback -->
  <springProperty scope="context" name="ROOT_LEVEL" source="logging.level.root" defaultValue="INFO"/>
  <springProperty scope="context" name="APP_LEVEL" source="logging.level.com.tchalanet.server" defaultValue="DEBUG"/>
  <springProperty scope="context" name="WEB_LEVEL" source="logging.level.org.springframework.web" defaultValue="INFO"/>
  <springProperty scope="context" name="SEC_LEVEL" source="logging.level.org.springframework.security" defaultValue="INFO"/>
  <springProperty scope="context" name="OAUTH2_LEVEL" source="logging.level.org.springframework.security.oauth2" defaultValue="INFO"/>
  <springProperty scope="context" name="JWT_LEVEL" source="logging.level.org.springframework.security.oauth2.jwt" defaultValue="INFO"/>
  <springProperty scope="context" name="RS_LEVEL" source="logging.level.org.springframework.security.oauth2.server.resource" defaultValue="INFO"/>
  <springProperty scope="context" name="HIB_SQL_LEVEL" source="logging.level.org.hibernate.SQL" defaultValue="INFO"/>

  <property name="LOG_DIR" value="logs"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${CONSOLE_LOG_PATTERN}</pattern>
      <charset>utf8</charset>
    </encoder>
  </appender>

  <!-- Default loggers (apply everywhere unless overridden) -->
  <logger name="com.tchalanet.server" level="${APP_LEVEL}"/>
  <logger name="org.springframework.web" level="${WEB_LEVEL}"/>
  <logger name="org.springframework.security" level="${SEC_LEVEL}"/>
  <logger name="org.springframework.security.oauth2" level="${OAUTH2_LEVEL}"/>
  <logger name="org.springframework.security.oauth2.jwt" level="${JWT_LEVEL}"/>
  <logger name="org.springframework.security.oauth2.server.resource" level="${RS_LEVEL}"/>
  <logger name="org.hibernate.SQL" level="${HIB_SQL_LEVEL}"/>

  <root level="${ROOT_LEVEL}">
    <appender-ref ref="CONSOLE"/>
  </root>

  <!-- Dev/local: you can still force more verbosity -->
  <springProfile name="local,dev,local-ide">
    <logger name="com.tchalanet.server" level="DEBUG"/>
    <logger name="org.springframework.web" level="DEBUG"/>
    <logger name="org.springframework.security" level="DEBUG"/>
    <logger name="org.springframework.security.oauth2" level="DEBUG"/>
    <logger name="org.springframework.security.oauth2.jwt" level="DEBUG"/>
    <logger name="org.springframework.security.oauth2.server.resource" level="DEBUG"/>
    <logger name="org.hibernate.SQL" level="DEBUG"/>
  </springProfile>

  <springProfile name="prod">
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${LOG_DIR}/tchalanet-server.log</file>
      <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
        <Pattern>%d %-5level %c{1} [%thread] %msg%n</Pattern>
      </encoder>
      <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
        <fileNamePattern>${LOG_DIR}/archived/tchalanet-server.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
        <maxFileSize>10MB</maxFileSize>
        <maxHistory>30</maxHistory>
        <totalSizeCap>1GB</totalSizeCap>
      </rollingPolicy>
    </appender>

    <root level="${ROOT_LEVEL}">
      <appender-ref ref="FILE"/>
    </root>

    <logger name="com.tchalanet.server" level="INFO"/>
  </springProfile>

</configuration>
