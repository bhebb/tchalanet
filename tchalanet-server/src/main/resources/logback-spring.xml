<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Include Spring Boot's default configurations -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Define a property for the log directory -->
    <property name="LOG_DIR" value="logs"/>

    <!-- ====================================================== -->
    <!-- Appender for Console (default)                         -->
    <!-- ====================================================== -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Use the default console pattern from Spring Boot -->
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>utf8</charset>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- ====================================================== -->
    <!-- Settings for Development/Local Profiles                -->
    <!-- ====================================================== -->
    <springProfile name="local,dev,local-ide">
        <!-- More specific logging levels for development -->
        <logger name="com.tchalanet.server" level="DEBUG"/>
        <logger name="org.springframework.web" level="DEBUG"/>
    </springProfile>

    <!-- ====================================================== -->
    <!-- Appender for Production Profile (Rolling File)         -->
    <!-- ====================================================== -->
    <springProfile name="prod">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_DIR}/tchalanet-server.log</file>
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <!-- For files, a more detailed pattern is often useful -->
                <Pattern>%d %-5level %c{1} [%thread] %msg%n</Pattern>
            </encoder>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <!-- daily rollover -->
                <fileNamePattern>${LOG_DIR}/archived/tchalanet-server.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>10MB</maxFileSize>
                <!-- keep 30 days' worth of history -->
                <maxHistory>30</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
        </appender>

        <root level="INFO">
            <appender-ref ref="FILE"/>
        </root>

        <!-- Keep application logs at INFO level in production -->
        <logger name="com.tchalanet.server" level="INFO"/>
    </springProfile>

</configuration>
