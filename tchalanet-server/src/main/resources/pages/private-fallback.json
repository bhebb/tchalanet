{
  "currentLang": "fr",
  "langs": ["fr"],
  "context": "dashboard-private",
  "version": "fallback-1",
  "theme": {
    "presetId": "violet-green",
    "mode": "light",
    "density": -1,
    "overrides": {
      "vars": {
        "--tch-header-bg": "#000000",
        "--tch-header-fg": "#FFD700",
        "--dark:--tch-header-bg": "#000000",
        "--dark:--tch-header-fg": "#FFD700"
      },
      "fontHref": "https://fonts.example.com/Inter.css"
    }
  },
  "header": {
    "component": "PrivateHeader",
    "properties": {
      "brand": {
        "name": "Tchalanet"
      }
    }
  },
  "nav": {
    "header": [],
    "sidenav": [
      {
        "labelKey": "nav.dashboard",
        "path": "/app/dashboard",
        "icon": "dashboard"
      }
    ]
  },
  "layout": {
    "component": "GridLayout",
    "rows": [
      {
        "columns": [
          {
            "span": 12,
            "widgets": [
              {
                "component": "InfoWidget",
                "properties": {
                  "title": "Console prête",
                  "message": "Configuration par défaut appliquée. Veuillez contacter l’administrateur si les données tardent à arriver."
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "component": "PrivateFooter",
    "properties": {
      "brand": {
        "name": "Tchalanet Console"
      }
    }
  },
  "features": [],
  "i18n": {
    "fr": {
      "nav.dashboard": "Tableau de bord"
    }
  },
  "issues": []
}
