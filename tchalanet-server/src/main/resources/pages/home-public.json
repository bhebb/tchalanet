{
  "currentLang": "fr",
  "langs": ["fr", "en", "ht"],
  "context": "home-public",
  "theme": {
    "presetId": "tchalanet",
    "mode": "light",
    "density": -1,
    "overrides": {
      "vars": {}
    }
  },
  "header": {
    "component": "PublicHeader",
    "properties": {
      "brand": {
        "logo": "/assets/branding/logo-tchalanet.svg",
        "name": "Tchalanet",
        "href": "/"
      },
      "navigation": [
        {
          "labelKey": "nav.home",
          "path": "/"
        },
        {
          "labelKey": "nav.features",
          "path": "/features"
        },
        {
          "labelKey": "nav.pricing",
          "path": "/pricing"
        },
        {
          "labelKey": "nav.verify",
          "path": "/verifier",
          "flag": "ff.ticket.verify"
        }
      ],
      "actions": {
        "search": {
          "flag": "ff.search.enabled"
        },
        "lang": {
          "flag": "ff.lang.enabled"
        },
        "theme": {
          "flag": "ff.theme.enabled"
        }
      },
      "cta": {
        "public": {
          "labelKey": "cta.try",
          "path": "/demo",
          "flag": "ff.cta.public"
        },
        "private": {
          "labelKey": "cta.dashboard",
          "path": "/app/dashboard",
          "flag": "ff.cta.private"
        }
      },
      "account": {
        "public": {
          "labelKey": "auth.login",
          "path": "/auth/login",
          "avatar": "generic"
        },
        "private": {
          "labelKey": "auth.profile",
          "path": "/app/profile",
          "avatar": "user"
        }
      }
    }
  },
  "layout": {
    "component": "GridLayout",
    "rows": [
      {
        "columns": [
          {
            "span": 12,
            "widgets": [
              {
                "component": "HeroWidget",
                "properties": {
                  "eyebrow": "home.hero.eyebrow",
                  "title": "home.hero.title",
                  "subtitle": "home.hero.subtitle",
                  "align": "left",
                  "image": {
                    "src": "/assets/hero/hero-main.svg",
                    "altKey": "home.hero.imageAlt",
                    "width": 560,
                    "height": 420,
                    "srcset": "/assets/images/hero-main.webp 1x, /assets/images/hero-main@2x.webp 2x",
                    "sizes": "(min-width:1024px) 560px, 90vw"
                  },
                  "primaryCta": {
                    "labelKey": "home.hero.cta",
                    "path": "/register"
                  },
                  "secondaryCta": {
                    "labelKey": "home.hero.demo",
                    "path": "/demo"
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "columns": [
          {
            "span": 12,
            "widgets": [
              {
                "component": "NewsBannerWidget",
                "properties": {
                  "title": "Actualités",
                  "labelKey": "news.label",
                  "region": "ht|global",
                  "autoScroll": true,
                  "pauseOnHover": true,
                  "maxItems": 12,
                  "emptyStateKey": "news.empty",
                  "ui": {
                    "compact": true
                  },
                  "data": {
                    "items": [
                      {
                        "id": "1",
                        "title": "Jackpot record en Europe : 210M€",
                        "source": "AFP",
                        "href": "#",
                        "region": "global"
                      },
                      {
                        "id": "2",
                        "title": "Haïti : nouveau calendrier des tirages 3PM",
                        "source": "Le Nouvelliste",
                        "href": "#",
                        "region": "ht"
                      }
                    ]
                  },
                  "dataSource": {
                    "type": "http",
                    "url": "/api/news?region=ht,global&limit=12",
                    "method": "GET",
                    "cacheTTL": 300,
                    "fallbackPath": "$.properties.data.items"
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "columns": [
          {
            "span": 12,
            "widgets": [
              {
                "component": "DrawSwitcherWidget",
                "properties": {
                  "title": "Derniers résultats",
                  "config": {
                    "initialLotteryId": "tch-ht-3pm",
                    "ui": {
                      "showIcons": true,
                      "compact": true
                    }
                  },
                  "data": {
                    "lotteries": [
                      {
                        "id": "tch-ht-3pm",
                        "name": "Haïti 3PM",
                        "icon": "looks_3"
                      },
                      {
                        "id": "tch-ht-8pm",
                        "name": "Haïti 8PM",
                        "icon": "nights_stay"
                      },
                      {
                        "id": "tch-car-7pm",
                        "name": "Caraïbes 7PM",
                        "icon": "sunny"
                      }
                    ],
                    "results": {
                      "tch-ht-3pm": [
                        {
                          "lotteryId": "tch-ht-3pm",
                          "lotteryName": "Haïti 3PM",
                          "drawTime": "2025-09-11T18:05:00Z",
                          "numbers": [4, 12, 19, 7, 31]
                        }
                      ],
                      "tch-ht-8pm": [
                        {
                          "lotteryId": "tch-ht-8pm",
                          "lotteryName": "Haïti 8PM",
                          "drawTime": "2025-09-10T20:05:00Z",
                          "numbers": [2, 9, 18, 27, 33],
                          "bonus": [5]
                        }
                      ],
                      "tch-car-7pm": [
                        {
                          "lotteryId": "tch-car-7pm",
                          "lotteryName": "Caraïbes 7PM",
                          "drawTime": "2025-09-10T23:05:00Z",
                          "numbers": [6, 11, 22, 28, 34]
                        }
                      ]
                    },
                    "next": {
                      "tch-ht-3pm": {
                        "lotteryId": "tch-ht-3pm",
                        "lotteryName": "Haïti 3PM",
                        "nextDrawTime": "2025-09-12T19:00:00Z"
                      },
                      "tch-ht-8pm": {
                        "lotteryId": "tch-ht-8pm",
                        "lotteryName": "Haïti 8PM",
                        "nextDrawTime": "2025-09-12T01:00:00Z"
                      },
                      "tch-car-7pm": {
                        "lotteryId": "tch-car-7pm",
                        "lotteryName": "Caraïbes 7PM",
                        "nextDrawTime": "2025-09-12T23:00:00Z"
                      }
                    }
                  },
                  "dataSource": {
                    "type": "composite",
                    "endpoints": {
                      "lotteries": {
                        "url": "/api/lotteries?active=true",
                        "cacheTTL": 600
                      },
                      "results": {
                        "url": "/api/lotteries/{id}/results?limit=5",
                        "cacheTTL": 120
                      },
                      "next": {
                        "url": "/api/lotteries/{id}/next-draw",
                        "cacheTTL": 60
                      }
                    },
                    "fallbackPath": "$.properties.data"
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "columns": [
          {
            "span": 4,
            "widgets": [
              {
                "component": "FeatureCardWidget",
                "properties": {
                  "icon": "manage_accounts",
                  "title": "home.feature1.title",
                  "description": "home.feature1.desc",
                  "link": {
                    "labelKey": "home.feature.learnMore",
                    "path": "/features/multi-tenant"
                  }
                }
              }
            ]
          },
          {
            "span": 4,
            "widgets": [
              {
                "component": "FeatureCardWidget",
                "properties": {
                  "icon": "query_stats",
                  "title": "home.feature2.title",
                  "description": "home.feature2.desc",
                  "link": {
                    "labelKey": "home.feature.learnMore",
                    "path": "/features/analytics"
                  }
                }
              }
            ]
          },
          {
            "span": 4,
            "widgets": [
              {
                "component": "FeatureCardWidget",
                "properties": {
                  "icon": "verified_user",
                  "title": "home.feature3.title",
                  "description": "home.feature3.desc",
                  "link": {
                    "labelKey": "home.feature.learnMore",
                    "path": "/features/security"
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "columns": [
          {
            "span": 4,
            "widgets": [
              {
                "component": "FeatureCardWidget",
                "properties": {
                  "icon": "point_of_sale",
                  "title": "home.feature4.title",
                  "description": "home.feature4.desc",
                  "link": {
                    "labelKey": "home.feature.learnMore",
                    "path": "/features/pos"
