          },
          {
            "span": 4,
            "widgets": [
              {
                "component": "FeatureCardWidget",
                "properties": {
                  "icon": "apartment",
                  "title": "home.feature5.title",
                  "description": "home.feature5.desc",
                  "link": {
                    "labelKey": "home.feature.learnMore",
                    "path": "/features/multi-company"
                  }
                }
              }
            ]
          },
          {
            "span": 4,
            "widgets": [
              {
                "component": "FeatureCardWidget",
                "properties": {
                  "icon": "tune",
                  "title": "home.feature6.title",
                  "description": "home.feature6.desc",
                  "link": {
                    "labelKey": "home.feature.learnMore",
                    "path": "/features/config"
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "columns": [
          {
            "span": 12,
            "widgets": [
              {
                "component": "HeroWidget",
                "properties": {
                  "title": "Connected Borlette Bank",
                  "subtitle": "Intégrez dépôts, trésorerie et paiements en toute simplicité.",
                  "image": {
                    "src": "/assets/hero/connected-bank.svg",
                    "alt": "Banque connectée"
                  },
                  "primaryCta": {
                    "label": "En savoir plus",
                    "link": "/features/bank"
                  },
                  "align": "center"
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "footer": {
