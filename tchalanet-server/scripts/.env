# Configuration E2E réelle pour localhost:8080

# ============================================================
# Base URL API
# ============================================================
TCH_BASE_URL="http://localhost:8080/api/v1"

# ============================================================
# OAuth2 / Token
# ============================================================
TCH_KEYCLOAK_TOKEN_URL="http://localhost:8081/realms/tchalanet/protocol/openid-connect/token"
TCH_KEYCLOAK_CLIENT_ID="tchalanet-swagger"
TCH_KEYCLOAK_CLIENT_SECRET=""
TCH_SELLER_USERNAME="cashier"
TCH_SELLER_PASSWORD="cashier"

# ============================================================
# Contexte opérationnel
# ============================================================
TCH_TENANT_CODE="demo"
TCH_OUTLET_ID="00000000-0000-0000-0000-000000003001"
TCH_TERMINAL_ID="00000000-0000-0000-0000-000000003101"

# ============================================================
# Configuration des bets multi-jeux
# ============================================================
TCH_GAME_PROFILES="BOLET,MARYAJ,LOTO3"
TCH_SELECTION_PLAN="BOLET=2,MARYAJ=3,LOTO3=2,LOTO4=2,LOTO5=1"
TCH_SELL_MODE="SINGLE_TICKET_MULTI_GAME"
TCH_SELECTIONS_PER_TICKET="3"

# ============================================================
# Configuration de la vente
# ============================================================
TCH_DRAW_LIMIT="20"
TCH_STAKE_CENTS="100"
TCH_ARTIFACT_DIR="target/e2e/tickets"
