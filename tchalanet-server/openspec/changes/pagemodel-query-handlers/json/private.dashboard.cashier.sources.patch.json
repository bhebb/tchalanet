{
  "logical_id": "private.dashboard.cashier",
  "changes": [
    {
      "path": "model.content.widgets.dashboard.cashier.overview.binding.source",
      "from": "cashier.overview",
      "to": "cashier_overview"
    },
    {
      "path": "model.content.widgets.dashboard.cashier.quick_sale.binding.source",
      "from": "quick_sale",
      "to": "cashier_quick_sale"
    },
    {
      "path": "model.content.widgets.dashboard.cashier.recent_tickets.binding.source",
      "from": "recent_tickets",
      "to": "cashier_recent_tickets"
    },
    {
      "path": "model.content.widgets.dashboard.cashier.session.binding.source",
      "from": "session",
      "to": "cashier_session"
    },
    {
      "path": "model.content.widgets.dashboard.cashier.next_draws",
      "op": "add",
      "value": {
        "type": "NextDrawsWidget",
        "binding": {
          "mode": "dynamic",
          "source": "cashier_next_draws"
        },
        "props": {
          "title_key": "dashboard.cashier.next_draws.title",
          "limit": 8
        }
      }
    }
  ]
}
