{
  "shell": {
    "header": {
      "component": "PublicHeader",
      "binding": {
        "mode": "dynamic",
        "source": "json_file"
      },
      "props": {
        "file_key": "public_header_links",
        "show_search": true,
        "show_language": true,
        "show_theme_toggle": true
      }
    },
    "footer": {
      "component": "PublicFooter",
      "binding": {
        "mode": "dynamic",
        "source": "json_file"
      },
      "props": {
        "file_key": "public_footer_links"
      }
    }
  },
  "content": {
    "widgets_patch": {
      "home.public.draw_results": {
        "type": "PublicDrawResultsWidget",
        "binding": {
          "mode": "dynamic",
          "source": "public_draw_results"
        },
        "props": {
          "title_key": "home.draw_results.title",
          "include_history": false,
          "history_limit": 0,
          "include_next_by_slot": true,
          "include_latest_by_slot": true
        }
      },
      "home.public.news": {
        "type": "PublicNewsWidget",
        "binding": {
          "mode": "dynamic",
          "source": "public_news"
        },
        "props": {
          "title_key": "home.news.title",
          "max_items": 4
        }
      }
    }
  }
}
