{
  "code": "private.dashboard.cashier",
  "logical_id": "private.dashboard.cashier",
  "name": "Cashier dashboard",
  "label": "cashier dashboard",
  "schema_version": 1,
  "schema": {},
  "is_default": true,
  "is_system": true,
  "description": "Tableau de bord pour le caissier: ventes rapides, tickets récents et gestion de session.",
  "model": {
    "meta": {
      "id": "private.dashboard.cashier",
      "scope": "private",
      "slug": "dashboard",
      "context": "private_dashboard_cashier",
      "schema_version": 1,
      "langs": ["fr", "en", "ht"],
      "default_lang": "fr",
      "description": "Interface simplifiée pour le caissier: quick sales, tickets et résumé de session."
    },
    "theme": {
      "presetId": "tchalanet_default",
      "mode": "light",
      "density": 0
    },
    "shell": {
      "header": {
        "component": "PrivateHeader",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "show_profile_menu": true,
          "file_key": "private_header_cashier"
        }
      },
      "sidenav": {
        "component": "PrivateSidenav",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "collapsible": true,
          "file_key": "private_sidebar_cashier"
        }
      },
      "footer": {
        "component": "PrivateFooter",
        "binding": {
          "mode": "dynamic",
          "source": "json_file"
        },
        "props": {
          "file_key": "private_footer_links"
        }
      }
    },
    "content": {
      "layout": {
        "component": "GridLayout",
        "rows": [
          {
            "id": "overview",
            "label_key": "layout.private_dashboard_cashier.overview",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.overview"]
              }
            ]
          },
          {
            "id": "quick_sale",
            "label_key": "layout.private_dashboard_cashier.quick_sale",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.quick_sale"]
              }
            ]
          },
          {
            "id": "recent_tickets",
            "label_key": "layout.private_dashboard_cashier.recent_tickets",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.recent_tickets"]
              }
            ]
          },
          {
            "id": "session",
            "label_key": "layout.private_dashboard_cashier.session",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.session"]
              }
            ]
          },
          {
            "id": "next_draws",
            "label_key": "layout.private_dashboard_cashier.next_draws",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.next_draws"]
              }
            ]
          },
          {
            "id": "limits",
            "label_key": "layout.private_dashboard_cashier.limits",
            "columns": [
              {
                "span": 12,
                "widgets": ["dashboard.cashier.limits"]
              }
            ]
          }
        ]
      },
      "widgets": {
        "dashboard.cashier.overview": {
          "type": "CashierOverviewWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_overview"
          },
          "props": {
            "title_key": "dashboard.cashier.overview.title"
          }
        },
        "dashboard.cashier.quick_sale": {
          "type": "QuickSaleWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_quick_sale"
          },
          "props": {
            "title_key": "dashboard.cashier.quick_sale.title",
            "max_games": 8,
            "include_next_draws": true
          }
        },
        "dashboard.cashier.recent_tickets": {
          "type": "RecentTicketsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_recent_tickets"
          },
          "props": {
            "title_key": "dashboard.cashier.recent_tickets.title",
            "max_items": 10
          }
        },
        "dashboard.cashier.session": {
          "type": "SessionSummaryWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_session"
          },
          "props": {
            "title_key": "dashboard.cashier.session.title"
          }
        },
        "dashboard.cashier.next_draws": {
          "type": "NextDrawsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_next_draws"
          },
          "props": {
            "title_key": "dashboard.cashier.next_draws.title",
            "max_items": 10,
            "include_countdown": true
          }
        },
        "dashboard.cashier.limits": {
          "type": "CashierLimitsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "cashier_limits"
          },
          "props": {
            "title_key": "dashboard.cashier.limits.title"
          }
        },
        "dashboard.cashier.quick_actions": {
          "type": "QuickActionsWidget",
          "binding": {
            "mode": "dynamic",
            "source": "json_file"
          },
          "props": {
            "title_key": "dashboard.cashier.quick_actions.title",
            "file_key": "private_cashier_quick_actions"
          }
        }
      }
    }
  }
}
