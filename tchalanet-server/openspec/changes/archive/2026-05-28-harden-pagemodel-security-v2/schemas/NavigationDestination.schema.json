{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NavigationDestination",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "destination",
        "group",
        "action"
      ]
    },
    "label_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "label": {
      "type": [
        "string",
        "null"
      ]
    },
    "path": {
      "type": [
        "string",
        "null"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "internal",
        "external",
        "action"
      ]
    },
    "icon": {
      "type": [
        "string",
        "null"
      ]
    },
    "image": {
      "anyOf": [
        {
          "$ref": "ImageRef.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "active_match": {
      "type": "string",
      "enum": [
        "exact",
        "prefix",
        "none"
      ]
    },
    "disabled": {
      "type": "boolean"
    },
    "reason_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "badge": {
      "type": [
        "object",
        "null"
      ]
    },
    "children": {
      "type": "array"
    }
  },
  "required": [
    "id",
    "type",
    "label_key",
    "label",
    "path",
    "kind",
    "icon",
    "image",
    "active_match",
    "disabled",
    "reason_key",
    "badge",
    "children"
  ]
}