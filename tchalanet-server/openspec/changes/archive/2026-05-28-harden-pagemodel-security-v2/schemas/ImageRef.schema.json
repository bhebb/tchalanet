{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ImageRef",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "url": {
      "type": [
        "string",
        "null"
      ]
    },
    "alt_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "title_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "width": {
      "type": [
        "integer",
        "null"
      ]
    },
    "height": {
      "type": [
        "integer",
        "null"
      ]
    },
    "aspect_ratio": {
      "type": [
        "string",
        "null"
      ]
    },
    "loading": {
      "type": "string",
      "enum": [
        "eager",
        "lazy"
      ]
    }
  },
  "required": [
    "url",
    "alt_key",
    "title_key",
    "width",
    "height",
    "aspect_ratio",
    "loading"
  ]
}